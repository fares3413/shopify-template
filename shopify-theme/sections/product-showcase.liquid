<section class="product-showcase section-padding" id="ProductShowcase-{{ section.id }}">
  <div class="page-width">

    <!-- Body: image left + heading + product carousel right -->
    <div class="product-showcase__body">

      <!-- Left: static image -->
      <div class="product-showcase__image-col">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            alt="{{ section.settings.image.alt | escape }}"
            class="product-showcase__image"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'product-showcase__image product-showcase__placeholder' }}
        {%- endif -%}
      </div>

      <!-- Right: heading + product cards + dots -->
      <div class="product-showcase__product-col">
        <!-- Header inside right column -->
        {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
          <div class="product-showcase__header">
            {%- if section.settings.eyebrow != blank -%}
              <p class="product-showcase__eyebrow">{{ section.settings.eyebrow }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h2 class="product-showcase__heading">
                {%- if section.settings.highlight_word != blank -%}
                  {{- section.settings.heading | replace: section.settings.highlight_word, '<span class="product-showcase__heading-highlight">' | append: section.settings.highlight_word | append: '</span>' -}}
                {%- else -%}
                  {{ section.settings.heading }}
                {%- endif -%}
              </h2>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="product-showcase__cards" id="PSCards-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- assign product = all_products[block.settings.product] -%}
            <div
              class="product-showcase__card{% if forloop.first %} is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              <!-- Product image -->
              <div class="product-showcase__card-image-wrap">
                {%- if product != blank and product.featured_image != blank -%}
                  <a href="{{ product.url }}" class="product-showcase__card-image-link">
                    <img
                      src="{{ product.featured_image | image_url: width: 800 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="product-showcase__card-image"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                    >
                  </a>
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-showcase__card-image' }}
                {%- endif -%}
              </div>

              <!-- Product info -->
              <div class="product-showcase__card-info">
                {%- if product != blank -%}
                  {%- if product.vendor != blank -%}
                    <span class="product-showcase__card-vendor">{{ product.vendor | upcase }}</span>
                  {%- endif -%}
                  <div class="product-showcase__card-name-price">
                    <a href="{{ product.url }}" class="product-showcase__card-name">{{ product.title }}</a>
                    <span class="product-showcase__card-price">{{ product.price | money }}</span>
                  </div>
                  {%- if block.settings.show_atc -%}
                    <a href="{{ product.url }}" class="btn btn--primary btn--full product-showcase__card-atc">
                      {{ block.settings.atc_label | default: 'Add to cart' }}
                    </a>
                  {%- endif -%}
                {%- else -%}
                  <span class="product-showcase__card-vendor">VENDOR</span>
                  <div class="product-showcase__card-name-price">
                    <span class="product-showcase__card-name">Example product</span>
                    <span class="product-showcase__card-price">€19,99</span>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Dot navigation -->
        {%- if section.blocks.size > 1 -%}
          <div class="product-showcase__dots" role="tablist" aria-label="Product navigation" id="PSDots-{{ section.id }}">
            {%- for block in section.blocks -%}
              <button
                class="product-showcase__dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                data-index="{{ forloop.index0 }}"
                aria-label="Product {{ forloop.index }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var section  = document.getElementById('ProductShowcase-{{ section.id }}');
  if (!section) return;
  var cards    = section.querySelectorAll('.product-showcase__card');
  var dots     = section.querySelectorAll('.product-showcase__dot');
  var current  = 0;

  if (cards.length <= 1) return;

  function goTo(idx) {
    cards[current].classList.remove('is-active');
    dots[current] && dots[current].classList.remove('is-active');
    dots[current] && dots[current].setAttribute('aria-selected', 'false');
    current = (idx + cards.length) % cards.length;
    cards[current].classList.add('is-active');
    dots[current] && dots[current].classList.add('is-active');
    dots[current] && dots[current].setAttribute('aria-selected', 'true');
  }

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.index, 10)); });
  });

  /* Auto-rotate if enabled */
  {%- if section.settings.autoplay -%}
  var speed = {{ section.settings.autoplay_speed | default: 4000 }};
  var timer = setInterval(function () { goTo(current + 1); }, speed);
  section.addEventListener('mouseenter', function () { clearInterval(timer); });
  section.addEventListener('mouseleave', function () {
    timer = setInterval(function () { goTo(current + 1); }, speed);
  });
  {%- endif -%}
}());
</script>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Premium Speakers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bring Quality Sound into Your Home"
    },
    {
      "type": "text",
      "id": "highlight_word",
      "label": "Word or phrase to highlight (cursive underline)",
      "info": "Must match exactly a word/phrase in your heading.",
      "default": "Your Home"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Left image"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate products",
      "default": false
    },
    {
      "type": "select",
      "id": "autoplay_speed",
      "label": "Rotate every",
      "options": [
        { "value": "2000", "label": "2 seconds" },
        { "value": "3000", "label": "3 seconds" },
        { "value": "4000", "label": "4 seconds" },
        { "value": "5000", "label": "5 seconds" }
      ],
      "default": "4000"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "show_atc",
          "label": "Show Add to Cart button",
          "default": false
        },
        {
          "type": "text",
          "id": "atc_label",
          "label": "Button label",
          "default": "Add to cart"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
