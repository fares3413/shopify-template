<style>
  #LogoList-{{ section.id }} {
    --ll-band-color: {{ section.settings.band_color }};
    --ll-text-color: {{ section.settings.text_color }};
    --ll-speed: {{ section.settings.speed }};
    --ll-skew: {{ section.settings.skew_angle }}deg;
  }
</style>
<div class="logo-list-band" id="LogoList-{{ section.id }}">
  <div class="logo-list-band__skew">
    <div class="logo-list-band__inner">

      {%- if section.settings.heading != blank -%}
        <p class="logo-list-band__label">{{ section.settings.heading }}</p>
      {%- endif -%}

      <div class="logo-list-band__track" aria-label="{{ section.settings.heading | default: 'As featured in' }}">
        <div class="logo-list-band__marquee">
          {%- for block in section.blocks -%}
            <div class="logo-list-band__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" target="_blank" rel="noopener" class="logo-list-band__link">{%- endif -%}
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 240 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.alt_text | escape }}"
                  class="logo-list-band__logo"
                  width="140" height="56"
                  loading="lazy"
                >
              {%- else -%}
                <span class="logo-list-band__placeholder">{{ block.settings.alt_text | default: 'BRAND' }}</span>
              {%- endif -%}
              {%- if block.settings.link != blank -%}</a>{%- endif -%}
            </div>
          {%- endfor -%}
          <!-- Duplicate set for seamless loop -->
          {%- for block in section.blocks -%}
            <div class="logo-list-band__item" aria-hidden="true">
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 240 }}" alt="" class="logo-list-band__logo" width="140" height="56" loading="lazy">
              {%- else -%}
                <span class="logo-list-band__placeholder">{{ block.settings.alt_text | default: 'BRAND' }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Logo List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label text",
      "default": "As featured in"
    },
    {
      "type": "color",
      "id": "band_color",
      "label": "Band background color",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text / logo tint color",
      "default": "#1a1a1a"
    },
    {
      "type": "select",
      "id": "speed",
      "label": "Scroll speed",
      "options": [
        { "value": "20s", "label": "Slow" },
        { "value": "14s", "label": "Medium" },
        { "value": "8s",  "label": "Fast" }
      ],
      "default": "14s"
    },
    {
      "type": "range",
      "id": "skew_angle",
      "min": -8,
      "max": 0,
      "step": 1,
      "unit": "deg",
      "label": "Diagonal angle",
      "default": -4
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Brand name (fallback text)",
          "default": "Brand"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo List",
      "blocks": [
        { "type": "logo", "settings": { "alt_text": "Rolling Stone" } },
        { "type": "logo", "settings": { "alt_text": "Wired" } },
        { "type": "logo", "settings": { "alt_text": "TechCrunch" } },
        { "type": "logo", "settings": { "alt_text": "Pitchfork" } },
        { "type": "logo", "settings": { "alt_text": "NME" } }
      ]
    }
  ]
}
{% endschema %}
