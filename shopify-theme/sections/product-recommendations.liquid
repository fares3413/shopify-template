<section class="product-recommendations section-padding" id="ProductRecommendations" data-product-id="{{ product.id }}" data-url="{{ routes.product_recommendations_url }}">
  <div class="page-width">
    <h2 class="product-recommendations__heading">{{ section.settings.heading | default: 'You may also like' }}</h2>
    <div class="product-recommendations__grid" id="RecommendationsGrid">
      {%- assign recommendations = product.recommendations -%}
      {%- if recommendations.performed? and recommendations.products_count > 0 -%}
        {%- for rec in recommendations.products limit: 4 -%}
          {% render 'product-card', product: rec, show_vendor: true %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
