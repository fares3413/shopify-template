<section class="usp-row" id="UspRow-{{ section.id }}">
  <div class="usp-row__inner page-width">
    {%- for block in section.blocks -%}
      <div class="usp-row__item" {{ block.shopify_attributes }}>
        <div class="usp-row__icon">
          {%- case block.settings.icon -%}
            {%- when 'headphone' -%}{% render 'icon-headphone' %}
            {%- when 'truck' -%}{% render 'icon-truck' %}
            {%- when 'gift' -%}{% render 'icon-gift' %}
            {%- when 'shield' -%}{% render 'icon-shield' %}
            {%- when 'check' -%}{% render 'icon', name: 'check', size: 22 %}
            {%- when 'star' -%}{% render 'icon', name: 'star', size: 22 %}
            {%- else -%}{% render 'icon-shield' %}
          {%- endcase -%}
        </div>
        <div class="usp-row__text">
          {%- if block.settings.heading != blank -%}
            <span class="usp-row__heading">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="usp-row__link">{{ block.settings.heading }}</a>
              {%- else -%}
                {{ block.settings.heading }}
              {%- endif -%}
            </span>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <span class="usp-row__desc">{{ block.settings.text }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "USP Row",
  "settings": [],
  "blocks": [
    {
      "type": "usp",
      "name": "USP item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "headphone", "label": "Headphone" },
            { "value": "truck", "label": "Truck / Shipping" },
            { "value": "gift", "label": "Gift / Referral" },
            { "value": "shield", "label": "Shield / Security" },
            { "value": "check", "label": "Check" },
            { "value": "star", "label": "Star" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Customer service"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "We're always here to help you"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "USP Row",
      "blocks": [
        { "type": "usp", "settings": { "icon": "headphone", "heading": "Customer service", "text": "It's not actually free we just price it into the products." } },
        { "type": "usp", "settings": { "icon": "truck", "heading": "Fast Free Shipping", "text": "Get free shipping on orders of $150 or more" } },
        { "type": "usp", "settings": { "icon": "gift", "heading": "Refer a friend", "text": "Refer a friend and get 15% off each other." } },
        { "type": "usp", "settings": { "icon": "shield", "heading": "Secure payment", "text": "Your payment information is processed securely" } }
      ]
    }
  ]
}
{% endschema %}
