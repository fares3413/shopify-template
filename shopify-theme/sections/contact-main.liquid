{%- if section.settings.show_map and section.settings.map_embed != blank -%}
  <div class="contact-map">
    <div class="contact-map__embed">
      {{ section.settings.map_embed }}
    </div>
  </div>
{%- endif -%}

<section class="contact-page section-padding" id="ContactPage-{{ section.id }}">
  <div class="page-width">

    <!-- Header -->
    <div class="contact-page__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="contact-page__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="contact-page__title">{{ section.settings.heading | default: page.title | default: 'Contact Us' }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="contact-page__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="contact-page__inner">

      <!-- ── Form column ── -->
      <div class="contact-page__form-col">

        {%- form 'contact', id: 'ContactForm-{{ section.id }}' -%}

          {%- if form.posted_successfully? -%}
            <div class="contact-page__success" role="alert">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <p>{{ section.settings.success_message | default: "Thanks for reaching out! We'll get back to you within 1–2 business days." }}</p>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact-page__error" role="alert">
              {%- for field in form.errors -%}
                <p>{{ field | capitalize }}: {{ form.errors.messages[field] }}</p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <!-- Name + Email -->
          <div class="contact-page__row">
            <div class="contact-page__field">
              <label for="ContactName-{{ section.id }}" class="visually-hidden">Name</label>
              <input
                type="text"
                id="ContactName-{{ section.id }}"
                name="contact[name]"
                placeholder="Name"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                class="contact-page__input"
                autocomplete="name"
              >
            </div>
            <div class="contact-page__field">
              <label for="ContactEmail-{{ section.id }}" class="visually-hidden">Email</label>
              <input
                type="email"
                id="ContactEmail-{{ section.id }}"
                name="contact[email]"
                placeholder="Email"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                class="contact-page__input"
                autocomplete="email"
                required
              >
            </div>
          </div>

          <!-- Phone + Subject -->
          <div class="contact-page__row">
            <div class="contact-page__field">
              <label for="ContactPhone-{{ section.id }}" class="visually-hidden">Phone number</label>
              <input
                type="tel"
                id="ContactPhone-{{ section.id }}"
                name="contact[phone]"
                placeholder="Phone number"
                class="contact-page__input"
                autocomplete="tel"
              >
            </div>
            <div class="contact-page__field contact-page__field--select">
              <label for="ContactSubject-{{ section.id }}" class="visually-hidden">Subject</label>
              <select
                id="ContactSubject-{{ section.id }}"
                name="contact[subject]"
                class="contact-page__input contact-page__select"
              >
                <option value="" disabled selected>Subject</option>
                {%- assign subject_opts = section.settings.subject_options | newline_to_br | split: '<br />' -%}
                {%- for opt in subject_opts -%}
                  {%- assign opt_clean = opt | strip -%}
                  {%- if opt_clean != blank -%}
                    <option value="{{ opt_clean | escape }}">{{ opt_clean }}</option>
                  {%- endif -%}
                {%- endfor -%}
              </select>
              <span class="contact-page__select-arrow" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </div>
          </div>

          <!-- Message -->
          <div class="contact-page__field">
            <label for="ContactMessage-{{ section.id }}" class="visually-hidden">Message</label>
            <textarea
              id="ContactMessage-{{ section.id }}"
              name="contact[body]"
              placeholder="Message"
              rows="6"
              class="contact-page__input contact-page__textarea"
            >{% if form.body %}{{ form.body }}{% endif %}</textarea>
          </div>

          <button type="submit" class="btn btn--primary contact-page__submit">
            {{ section.settings.button_label | default: 'Send message' }}
          </button>

          {%- if section.settings.show_recaptcha_notice -%}
            <p class="contact-page__recaptcha">
              This site is protected by hCaptcha and the hCaptcha
              <a href="https://www.hcaptcha.com/privacy" target="_blank" rel="noopener">Privacy Policy</a>
              and <a href="https://www.hcaptcha.com/terms" target="_blank" rel="noopener">Terms of Service</a> apply.
            </p>
          {%- endif -%}

        {%- endform -%}
      </div>

      <!-- ── Info column ── -->
      <div class="contact-page__info-col">

        {%- if section.settings.address != blank -%}
          <div class="contact-page__info-item">
            <div class="contact-page__info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="contact-page__info-label">Address</span>
              <p class="contact-page__info-text">{{ section.settings.address }}</p>
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.email_1 != blank -%}
          <div class="contact-page__info-item">
            <div class="contact-page__info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <span class="contact-page__info-label">Email</span>
              <a href="mailto:{{ section.settings.email_1 }}" class="contact-page__info-link">{{ section.settings.email_1 }}</a>
              {%- if section.settings.email_2 != blank -%}
                <a href="mailto:{{ section.settings.email_2 }}" class="contact-page__info-link">{{ section.settings.email_2 }}</a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.phone != blank -%}
          <div class="contact-page__info-item">
            <div class="contact-page__info-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.58 3.38 2 2 0 0 1 3.55 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.69a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <span class="contact-page__info-label">Phone</span>
              <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-page__info-link">{{ section.settings.phone }}</a>
              {%- if section.settings.hours != blank -%}
                <span class="contact-page__info-hours">{{ section.settings.hours }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        <!-- Social -->
        <div class="contact-page__info-item">
          <div class="contact-page__info-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          </div>
          <div>
            <span class="contact-page__info-label">Follow us</span>
            <div class="contact-page__social">
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook" class="contact-page__social-link">{% render 'icon-facebook' %}</a>
              {%- endif -%}
              {%- if settings.social_twitter_link != blank -%}
                <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" aria-label="X / Twitter" class="contact-page__social-link">{% render 'icon-x' %}</a>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram" class="contact-page__social-link">{% render 'icon-instagram' %}</a>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube" class="contact-page__social-link">{% render 'icon-youtube' %}</a>
              {%- endif -%}
            </div>
          </div>
        </div>

      </div><!-- /.contact-page__info-col -->
    </div><!-- /.contact-page__inner -->
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    {
      "type": "header",
      "content": "Page header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Us"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>We'd love to hear from you. Our team is here to help.<br>Let your customers get in touch with you by filling out the email form below.</p>"
    },
    {
      "type": "header",
      "content": "Form"
    },
    {
      "type": "textarea",
      "id": "subject_options",
      "label": "Subject dropdown options (one per line)",
      "default": "Order inquiry\nReturn & refund\nProduct question\nPartnership\nOther"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send message"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for reaching out! We'll get back to you within 1–2 business days."
    },
    {
      "type": "checkbox",
      "id": "show_recaptcha_notice",
      "label": "Show hCaptcha notice",
      "default": true
    },
    {
      "type": "header",
      "content": "Contact info"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "620 King St W, Toronto, ON M5V 1M7, Canada"
    },
    {
      "type": "text",
      "id": "email_1",
      "label": "Email 1",
      "default": "contact@yourstore.com"
    },
    {
      "type": "text",
      "id": "email_2",
      "label": "Email 2 (optional)",
      "default": "sales@yourstore.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+33 (0) 31-305-210"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Opening hours",
      "default": "mo – fri: 09:00 – 17:00"
    },
    {
      "type": "header",
      "content": "Map (optional)"
    },
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show map above form",
      "default": false
    },
    {
      "type": "html",
      "id": "map_embed",
      "label": "Google Maps embed code"
    }
  ],
  "presets": [
    {
      "name": "Contact"
    }
  ]
}
{% endschema %}
