<section class="featured-product section-padding" id="FeaturedProduct-{{ section.id }}">

  <!-- Circular rotating stamp badge -->
  <div class="featured-product__stamp" aria-hidden="true">
    <svg viewBox="0 0 120 120" class="featured-product__stamp-svg">
      <defs>
        <path id="circlePath-{{ section.id }}" d="M 60,60 m -45,0 a 45,45 0 1,1 90,0 a 45,45 0 1,1 -90,0"/>
      </defs>
      <text class="featured-product__stamp-text">
        <textPath href="#circlePath-{{ section.id }}">• FEATURED • PRODUCT •&nbsp;&nbsp;</textPath>
      </text>
      <text x="60" y="68" text-anchor="middle" class="featured-product__stamp-icon">👍</text>
    </svg>
  </div>

  {%- assign fp = all_products[section.settings.product] -%}
  {%- if fp == blank -%}{%- assign fp = product -%}{%- endif -%}

  <div class="featured-product__inner page-width">

    <!-- ═══ GALLERY ═══ -->
    <div class="featured-product__gallery">

      <!-- Vertical thumbnails -->
      <div class="featured-product__thumbs" id="FPThumbs-{{ section.id }}">
        {%- if fp != blank and fp.images.size > 0 -%}
          {%- for image in fp.images limit: 7 -%}
            <button
              class="featured-product__thumb {% if forloop.first %}is-active{% endif %}"
              data-index="{{ forloop.index0 }}"
              data-src="{{ image | image_url: width: 900 }}"
              aria-label="View image {{ forloop.index }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <img
                src="{{ image | image_url: width: 120 }}"
                alt="{{ image.alt | default: fp.title | escape }}"
                width="72" height="72"
                loading="{{ forloop.first | iif: 'eager', 'lazy' }}"
              >
            </button>
          {%- endfor -%}
          {%- if fp.images.size > 7 -%}
            <button class="featured-product__thumb-more" aria-label="More images">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          {%- endif -%}
        {%- else -%}
          <button class="featured-product__thumb is-active">
            {{ 'product-1' | placeholder_svg_tag: 'featured-product__thumb-placeholder' }}
          </button>
          <button class="featured-product__thumb">{{ 'product-2' | placeholder_svg_tag: 'featured-product__thumb-placeholder' }}</button>
          <button class="featured-product__thumb">{{ 'product-3' | placeholder_svg_tag: 'featured-product__thumb-placeholder' }}</button>
          <button class="featured-product__thumb">{{ 'product-4' | placeholder_svg_tag: 'featured-product__thumb-placeholder' }}</button>
          <button class="featured-product__thumb">{{ 'product-5' | placeholder_svg_tag: 'featured-product__thumb-placeholder' }}</button>
          <button class="featured-product__thumb-more" aria-label="More images">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        {%- endif -%}
      </div>

      <!-- Large main image -->
      <div class="featured-product__main-image-wrap">
        {%- if fp != blank and fp.featured_image != blank -%}
          <img
            src="{{ fp.featured_image | image_url: width: 900 }}"
            alt="{{ fp.featured_image.alt | default: fp.title | escape }}"
            id="FPMainImage-{{ section.id }}"
            class="featured-product__main-image"
            width="{{ fp.featured_image.width }}"
            height="{{ fp.featured_image.height }}"
            loading="eager"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'featured-product__main-image featured-product__main-placeholder' }}
        {%- endif -%}
      </div>

    </div><!-- /.gallery -->

    <!-- ═══ PRODUCT INFO ═══ -->
    <div class="featured-product__info">

      <!-- Title + price on same row -->
      <div class="featured-product__title-row">
        <h2 class="featured-product__title">
          {%- if fp != blank -%}{{ fp.title }}{%- else -%}Example product{%- endif -%}
        </h2>
        <div class="featured-product__price">
          {%- if fp != blank -%}
            {%- if fp.compare_at_price > fp.price -%}
              <s class="featured-product__price--compare">{{ fp.compare_at_price | money }}</s>
            {%- endif -%}
            <span class="featured-product__price--current">{{ fp.price | money }}</span>
          {%- else -%}
            <span class="featured-product__price--current">€19,99</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Description -->
      {%- if fp != blank and fp.description != blank -%}
        <div class="featured-product__desc rte">
          {{ fp.description | truncatewords: 35 }}
        </div>
      {%- else -%}
        <p class="featured-product__desc">This area is used to describe your product's details. Tell customers about the look, feel, and style of your product. Add details on color, materials used, sizing, and where it was made.</p>
      {%- endif -%}

      <!-- Add to cart form -->
      {%- if fp != blank -%}
        {%- form 'product', fp, id: 'FPForm-{{ section.id }}', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ fp.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            class="btn btn--primary btn--full featured-product__atc"
            {% unless fp.available %}disabled{% endunless %}
          >
            {%- if fp.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
          </button>
        {%- endform -%}
      {%- else -%}
        <button type="button" class="btn btn--primary btn--full featured-product__atc">Add to cart</button>
      {%- endif -%}

      <!-- Share + Need help row -->
      <div class="featured-product__share-row">
        <div class="featured-product__share">
          <span class="featured-product__share-label">Share:</span>
          {%- assign share_url = fp.url | default: request.path | full_url | url_encode -%}
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on Facebook" class="featured-product__share-icon">{% render 'icon-facebook' %}</a>
          <a href="https://twitter.com/intent/tweet?url={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on X" class="featured-product__share-icon">{% render 'icon-x' %}</a>
          <a href="https://pinterest.com/pin/create/button/?url={{ share_url }}" target="_blank" rel="noopener" aria-label="Save to Pinterest" class="featured-product__share-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
          </a>
          <a href="mailto:?subject={{ fp.title | default: 'Check this out' | url_encode }}&body={{ share_url }}" aria-label="Share via email" class="featured-product__share-icon">{% render 'icon-mail' %}</a>
        </div>
        <a href="{{ fp.url | default: '#' }}" class="featured-product__help">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Need help?
        </a>
      </div>

      <!-- Trust / feature items -->
      {%- if section.blocks.size > 0 -%}
        <ul class="featured-product__features">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li class="featured-product__feature" {{ block.shopify_attributes }}>
                <span class="featured-product__feature-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}{% render 'icon-truck' %}
                    {%- when 'headphone' -%}{% render 'icon-headphone' %}
                    {%- when 'shield' -%}{% render 'icon-shield' %}
                    {%- when 'gift' -%}{% render 'icon-gift' %}
                    {%- else -%}{% render 'icon-shield' %}
                  {%- endcase -%}
                </span>
                <span class="featured-product__feature-text">{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <!-- View full details link -->
      <a href="{{ fp.url | default: '#' }}" class="featured-product__view-link">
        <span>View full details</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>

    </div><!-- /.info -->
  </div><!-- /.inner -->
</section>

<script>
(function() {
  var section = document.getElementById('FeaturedProduct-{{ section.id }}');
  if (!section) return;
  var thumbs = section.querySelectorAll('.featured-product__thumb[data-src]');
  var mainImage = section.querySelector('#FPMainImage-{{ section.id }}');
  if (!thumbs.length || !mainImage) return;

  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      thumbs.forEach(function(t) {
        t.classList.remove('is-active');
        t.setAttribute('aria-pressed', 'false');
      });
      thumb.classList.add('is-active');
      thumb.setAttribute('aria-pressed', 'true');
      mainImage.src = thumb.dataset.src;
    });
  });
})();
</script>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "headphone", "label": "Headphone (support)" },
            { "value": "shield", "label": "Shield (warranty/security)" },
            { "value": "gift", "label": "Gift (returns)" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "In stock! Ships within 1-2 business days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Product",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "text": "In stock! Ships within 1-2 business days." } },
        { "type": "feature", "settings": { "icon": "headphone", "text": "90-day risk-free trial" } },
        { "type": "feature", "settings": { "icon": "shield", "text": "2-Year Warranty" } },
        { "type": "feature", "settings": { "icon": "gift", "text": "Complimentary shipping & returns" } }
      ]
    }
  ]
}
{% endschema %}
