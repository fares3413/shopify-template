{% comment %}
  Reusable button snippet.
  Parameters:
    label   - (string) button text
    url     - (string) href, renders <a> if present, <button> otherwise
    style   - (string) 'primary' | 'outline' | 'white' | 'ghost', default 'primary'
    size    - (string) 'sm' | 'md' | 'lg', default 'md'
    full    - (boolean) full width
    icon    - (string) icon name to append
    type    - (string) button type attribute, default 'button'
    attrs   - (string) additional HTML attributes
  Usage:
    {% render 'button', label: 'Shop Now', url: collection.url, style: 'primary' %}
    {% render 'button', label: 'Add to cart', style: 'primary', full: true, type: 'submit' %}
{% endcomment %}

{%- assign btn_style = style | default: 'primary' -%}
{%- assign btn_size = size | default: 'md' -%}
{%- assign btn_classes = 'btn btn--' | append: btn_style -%}
{%- if btn_size == 'sm' -%}{%- assign btn_classes = btn_classes | append: ' btn--sm' -%}{%- endif -%}
{%- if btn_size == 'lg' -%}{%- assign btn_classes = btn_classes | append: ' btn--lg' -%}{%- endif -%}
{%- if full -%}{%- assign btn_classes = btn_classes | append: ' btn--full' -%}{%- endif -%}

{%- if url != blank -%}
  <a href="{{ url }}" class="{{ btn_classes }}" {{ attrs }}>
    {{- label -}}
    {%- if icon != blank -%}
      {% render 'icon', name: icon, size: 16 %}
    {%- endif -%}
  </a>
{%- else -%}
  <button type="{{ type | default: 'button' }}" class="{{ btn_classes }}" {{ attrs }}>
    {{- label -}}
    {%- if icon != blank -%}
      {% render 'icon', name: icon, size: 16 %}
    {%- endif -%}
  </button>
{%- endif -%}
