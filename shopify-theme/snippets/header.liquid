<header class="header" id="Header">
  <div class="header__inner">

    <div class="header__social header__social--desktop">
      {%- if settings.social_facebook_link != blank -%}
        <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Facebook">
          {% render 'icon-facebook' %}
        </a>
      {%- endif -%}
      {%- if settings.social_twitter_link != blank -%}
        <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="X (Twitter)">
          {% render 'icon-x' %}
        </a>
      {%- endif -%}
      {%- if settings.social_instagram_link != blank -%}
        <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Instagram">
          {% render 'icon-instagram' %}
        </a>
      {%- endif -%}
      {%- if settings.social_youtube_link != blank -%}
        <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="YouTube">
          {% render 'icon-youtube' %}
        </a>
      {%- endif -%}
    </div>

    <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="header__logo-image" width="140" height="40">
      {%- else -%}
        <span class="header__logo-text">{{ shop.name }}</span>
      {%- endif -%}
    </a>

    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {%- if settings.menu != blank -%}
        {%- for link in linklists[settings.menu].links -%}
          {%- if link.links != blank -%}
            <div class="header__nav-item header__nav-item--dropdown">
              <a href="{{ link.url }}" class="header__nav-link">
                {{ link.title }}
                {% render 'icon-chevron-down' %}
              </a>
              <ul class="header__dropdown">
                {%- for child_link in link.links -%}
                  <li><a href="{{ child_link.url }}" class="header__dropdown-link">{{ child_link.title }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link {% if link.active %}header__nav-link--active{% endif %}">
              {{ link.title }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <div class="header__actions">
      <button class="header__icon-btn" id="SearchToggle" aria-label="Search">
        {% render 'icon-search' %}
      </button>
      <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
        {% render 'icon-account' %}
      </a>
      <button class="header__icon-btn header__cart-btn" id="CartToggle" aria-label="Cart ({{ cart.item_count }})">
        {% render 'icon-cart' %}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </button>
    </div>

    <button class="header__mobile-menu-btn" id="MobileMenuToggle" aria-label="Menu" aria-expanded="false">
      {% render 'icon-menu' %}
    </button>

  </div>

  <div class="header__mobile-nav" id="MobileNav" aria-hidden="true">
    {%- if settings.menu != blank -%}
      {%- for link in linklists[settings.menu].links -%}
        <a href="{{ link.url }}" class="header__mobile-nav-link">{{ link.title }}</a>
      {%- endfor -%}
    {%- endif -%}
  </div>

  <div class="header__search-overlay" id="SearchOverlay">
    <div class="header__search-inner">
      <form action="{{ routes.search_url }}" method="get" class="header__search-form">
        <input type="hidden" name="type" value="product">
        <input type="text" name="q" placeholder="Search for products..." class="header__search-input" autofocus>
        <button type="submit" class="header__search-submit" aria-label="Submit search">
          {% render 'icon-search' %}
        </button>
      </form>
      <button class="header__search-close" id="SearchClose" aria-label="Close search">
        {% render 'icon-close' %}
      </button>
    </div>
  </div>
</header>
