<header class="header{% if section.settings.transparent_on_home and template.name == 'index' %} header--transparent{% endif %}" id="Header" data-sticky="{{ section.settings.sticky_header }}">
  <div class="header__bar">

    <!-- LEFT: social icons + logo -->
    <div class="header__left">
      <div class="header__social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="X">{% render 'icon-x' %}</a>
        {%- endif -%}
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>
        {%- endif -%}
      </div>

      <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
            class="header__logo-image"
            width="{{ settings.logo_width | default: 140 }}"
            height="auto"
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- CENTER: navigation -->
    {%- assign nav_menu = section.settings.menu | default: settings.menu -%}
    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {%- if nav_menu != blank -%}
        {%- for link in linklists[nav_menu].links -%}
          {%- if link.links != blank -%}
            <div class="header__nav-item header__nav-item--has-dropdown">
              <a href="{{ link.url }}" class="header__nav-link {% if link.active %}is-active{% endif %}">
                <span class="header__nav-link-text">{{ link.title }}</span>
                <span class="header__nav-link-dot" aria-hidden="true"></span>
                {% render 'icon-chevron-down' %}
              </a>
              <ul class="header__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="header__dropdown-link {% if child.active %}is-active{% endif %}">
                      {{ child.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link {% if link.active %}is-active{% endif %}">
              <span class="header__nav-link-text">{{ link.title }}</span>
              <span class="header__nav-link-dot" aria-hidden="true"></span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <!-- RIGHT: actions + mobile hamburger -->
    <div class="header__right">
      <div class="header__actions">
        <button class="header__icon-btn" id="SearchToggle" aria-label="Search" aria-expanded="false" aria-controls="SearchOverlay">
          {% render 'icon-search' %}
        </button>
        <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
          {% render 'icon-account' %}
        </a>
        <button class="header__icon-btn header__cart-btn" id="CartToggle" aria-label="Cart ({{ cart.item_count }})">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-count" aria-live="polite">{{ cart.item_count }}</span>
          {%- endif -%}
        </button>
      </div>

      <button
        class="header__mobile-btn"
        id="MobileMenuToggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="MobileNav"
      >
        <span class="header__mobile-btn-bar"></span>
        <span class="header__mobile-btn-bar"></span>
        <span class="header__mobile-btn-bar"></span>
      </button>
    </div>

  </div><!-- /.header__bar -->

  <!-- Mobile navigation drawer -->
  <nav class="header__mobile-nav" id="MobileNav" aria-hidden="true" aria-label="Mobile navigation">
    {%- if nav_menu != blank -%}
      {%- for link in linklists[nav_menu].links -%}
        <a href="{{ link.url }}" class="header__mobile-link {% if link.active %}is-active{% endif %}">
          {{ link.title }}
        </a>
        {%- if link.links != blank -%}
          {%- for child in link.links -%}
            <a href="{{ child.url }}" class="header__mobile-link header__mobile-link--child">{{ child.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    <div class="header__mobile-social">
      {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>{%- endif -%}
      {%- if settings.social_twitter_link != blank -%}<a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="X">{% render 'icon-x' %}</a>{%- endif -%}
      {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>{%- endif -%}
      {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>{%- endif -%}
    </div>
  </nav>

  <!-- Search overlay -->
  <div class="header__search-overlay" id="SearchOverlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
    <div class="header__search-inner">
      <form action="{{ routes.search_url }}" method="get" class="header__search-form" role="search">
        <input type="hidden" name="type" value="product">
        <input
          type="search"
          name="q"
          class="header__search-input"
          placeholder="Search products, collections…"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          aria-label="Search"
        >
        <button type="submit" class="header__search-submit" aria-label="Submit search">
          {% render 'icon-search' %}
        </button>
      </form>
      <button class="header__search-close" id="SearchClose" aria-label="Close search">
        {% render 'icon-close' %}
      </button>
    </div>
  </div>

</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header on scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_on_home",
      "label": "Transparent on homepage",
      "default": false,
      "info": "Makes the header background transparent over the hero section."
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
