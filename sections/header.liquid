{%- assign s = section.settings -%}

<header
  class="header{% if s.transparent_on_home and template.name == 'index' %} header--transparent{% endif %}"
  id="Header"
  data-sticky="{{ s.sticky_header }}"
  data-compact="{{ s.compact_on_scroll }}"
  data-compact-threshold="{{ s.scroll_threshold }}"
>

  <!-- ═══ FULL BAR (normal / top state) ═══ -->
  <div class="header__bar">

    <!-- LEFT: social icons + logo -->
    <div class="header__left">
      <div class="header__social">
        {%- if settings.social_facebook_link != blank -%}
          <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>
        {%- endif -%}
        {%- if settings.social_twitter_link != blank -%}
          <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="X">{% render 'icon-x' %}</a>
        {%- endif -%}
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>
        {%- endif -%}
      </div>

      <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: 300 }}"
            alt="{{ shop.name }}"
            class="header__logo-image"
            width="{{ settings.logo_width | default: 140 }}"
            height="auto"
            loading="eager"
            fetchpriority="high"
          >
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- CENTER: navigation -->
    {%- assign nav_menu = s.menu | default: settings.menu -%}
    <nav class="header__nav" role="navigation" aria-label="Main navigation">
      {%- if nav_menu != blank -%}
        {%- for link in linklists[nav_menu].links -%}
          {%- if link.links != blank -%}
            <div class="header__nav-item header__nav-item--has-dropdown">
              <a href="{{ link.url }}" class="header__nav-link {% if link.active %}is-active{% endif %}">
                <span class="header__nav-link-text">{{ link.title }}</span>
                <span class="header__nav-link-dot" aria-hidden="true"></span>
                {% render 'icon-chevron-down' %}
              </a>
              <ul class="header__dropdown" role="list">
                {%- for child in link.links -%}
                  <li>
                    <a href="{{ child.url }}" class="header__dropdown-link {% if child.active %}is-active{% endif %}">
                      {{ child.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="header__nav-link {% if link.active %}is-active{% endif %}">
              <span class="header__nav-link-text">{{ link.title }}</span>
              <span class="header__nav-link-dot" aria-hidden="true"></span>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </nav>

    <!-- RIGHT: actions + mobile hamburger -->
    <div class="header__right">
      <div class="header__actions">
        <button class="header__icon-btn" id="SearchToggle" aria-label="Search" aria-expanded="false" aria-controls="SearchOverlay">
          {% render 'icon-search' %}
        </button>
        <a href="{{ routes.account_url }}" class="header__icon-btn" aria-label="Account">
          {% render 'icon-account' %}
        </a>
        <button class="header__icon-btn header__cart-btn" id="CartToggle" aria-label="Cart ({{ cart.item_count }})">
          {% render 'icon-cart' %}
          {%- if cart.item_count > 0 -%}
            <span class="header__cart-count" aria-live="polite">{{ cart.item_count }}</span>
          {%- endif -%}
        </button>
      </div>

      <button
        class="header__mobile-btn"
        id="MobileMenuToggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="MobileNav"
      >
        <span class="header__mobile-btn-bar"></span>
        <span class="header__mobile-btn-bar"></span>
        <span class="header__mobile-btn-bar"></span>
      </button>
    </div>

  </div><!-- /.header__bar -->


  {%- comment -%} ── COMPACT PILL (scroll state) ── {%- endcomment -%}
  {%- if s.compact_on_scroll -%}

    <div
      class="header__pill"
      id="HeaderPill"
      aria-hidden="true"
      style="
        --pill-bg:    {{ s.compact_bg }};
        --pill-color: {{ s.compact_text_color }};
        --pill-width: {{ s.compact_max_width }}px;
      "
    >
      {%- comment -%} Left: hamburger (delegates to main mobile toggle) {%- endcomment -%}
      <button
        class="header__pill-btn"
        id="HeaderPillMenu"
        aria-label="Toggle menu"
        type="button"
      >
        <svg width="17" height="13" viewBox="0 0 17 13" fill="none" aria-hidden="true">
          <rect width="17" height="2" rx="1" fill="currentColor"/>
          <rect y="5.5" width="12" height="2" rx="1" fill="currentColor"/>
          <rect y="11" width="17" height="2" rx="1" fill="currentColor"/>
        </svg>
      </button>

      {%- comment -%} Center: logo / store name {%- endcomment -%}
      <a href="{{ routes.root_url }}" class="header__pill-logo" aria-label="{{ shop.name }}">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            class="header__pill-logo-img"
            height="26"
            width="auto"
            loading="eager"
          >
        {%- else -%}
          {{ shop.name | upcase }}
        {%- endif -%}
      </a>

      {%- comment -%} Right: cart {%- endcomment -%}
      <a href="/cart" class="header__pill-btn" aria-label="Cart ({{ cart.item_count }})">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__pill-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} Floating promo badge {%- endcomment -%}
    {%- if s.show_promo_badge and s.promo_badge_text != blank -%}
      <div
        class="header__promo-badge"
        aria-hidden="true"
        style="background: {{ s.promo_badge_bg }}; color: {{ s.promo_badge_color }};"
      >
        {{ s.promo_badge_text }}
      </div>
    {%- endif -%}

    {%- comment -%} Floating status pill {%- endcomment -%}
    {%- if s.show_status_pill and s.status_pill_text != blank -%}
      <div
        class="header__status-pill"
        aria-hidden="true"
        style="background: {{ s.status_pill_bg }}; color: {{ s.status_pill_color }};"
      >
        {{ s.status_pill_text }}
      </div>
    {%- endif -%}

  {%- endif -%}


  <!-- Mobile navigation drawer -->
  <nav class="header__mobile-nav" id="MobileNav" aria-hidden="true" aria-label="Mobile navigation">
    {%- if nav_menu != blank -%}
      {%- for link in linklists[nav_menu].links -%}
        <a href="{{ link.url }}" class="header__mobile-link {% if link.active %}is-active{% endif %}">
          {{ link.title }}
        </a>
        {%- if link.links != blank -%}
          {%- for child in link.links -%}
            <a href="{{ child.url }}" class="header__mobile-link header__mobile-link--child">{{ child.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endif -%}
    <div class="header__mobile-social">
      {%- if settings.social_facebook_link != blank -%}<a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>{%- endif -%}
      {%- if settings.social_twitter_link != blank -%}<a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="X">{% render 'icon-x' %}</a>{%- endif -%}
      {%- if settings.social_instagram_link != blank -%}<a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>{%- endif -%}
      {%- if settings.social_youtube_link != blank -%}<a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" class="header__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>{%- endif -%}
    </div>
  </nav>

  <!-- Search overlay -->
  <div class="header__search-overlay" id="SearchOverlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Search">
    <div class="header__search-inner">
      <form action="{{ routes.search_url }}" method="get" class="header__search-form" role="search">
        <input type="hidden" name="type" value="product">
        <input
          type="search"
          name="q"
          class="header__search-input"
          placeholder="Search products, collections…"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
          aria-label="Search"
        >
        <button type="submit" class="header__search-submit" aria-label="Submit search">
          {% render 'icon-search' %}
        </button>
      </form>
      <button class="header__search-close" id="SearchClose" aria-label="Close search">
        {% render 'icon-close' %}
      </button>
    </div>
  </div>

</header>

{%- comment -%} Scroll behaviour handled by assets/theme.js updateHeader() {%- endcomment -%}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "sticky_header",
      "label": "Sticky header on scroll",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "transparent_on_home",
      "label": "Transparent on homepage",
      "default": false,
      "info": "Makes the header background transparent over the hero section."
    },
    {
      "type": "header",
      "content": "Compact scroll header"
    },
    {
      "type": "checkbox",
      "id": "compact_on_scroll",
      "label": "Enable floating pill header on scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_threshold",
      "label": "Scroll distance before activating (px)",
      "min": 40,
      "max": 300,
      "step": 20,
      "default": 80
    },
    {
      "type": "range",
      "id": "compact_max_width",
      "label": "Pill max width (px)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 360
    },
    {
      "type": "color",
      "id": "compact_bg",
      "label": "Pill background color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "compact_text_color",
      "label": "Pill text / icon color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Floating promo badge"
    },
    {
      "type": "checkbox",
      "id": "show_promo_badge",
      "label": "Show promo badge",
      "default": true
    },
    {
      "type": "text",
      "id": "promo_badge_text",
      "label": "Promo badge text",
      "default": "20% OFF!"
    },
    {
      "type": "color",
      "id": "promo_badge_bg",
      "label": "Badge background",
      "default": "#FDE68A"
    },
    {
      "type": "color",
      "id": "promo_badge_color",
      "label": "Badge text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Floating status pill"
    },
    {
      "type": "checkbox",
      "id": "show_status_pill",
      "label": "Show status pill",
      "default": true
    },
    {
      "type": "text",
      "id": "status_pill_text",
      "label": "Status pill text",
      "default": "Sold Out"
    },
    {
      "type": "color",
      "id": "status_pill_bg",
      "label": "Status pill background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "status_pill_color",
      "label": "Status pill text color",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
