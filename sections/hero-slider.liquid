{%- assign slide_count = section.blocks.size -%}
{%- assign s = section.settings -%}

<div
  class="hero-slider hero-slider--editorial"
  id="HeroSlider-{{ section.id }}"
  data-autoplay="{{ s.autoplay }}"
  data-autoplay-speed="{{ s.autoplay_speed }}"
  style="
    --slide-height: {{ s.height }}vh;
    --hs-bg: {{ s.hero_bg }};
    --hs-text: {{ s.hero_text_color }};
  "
>

  {%- comment -%} ── Floating top hero bar (outside track, always on top) ── {%- endcomment -%}
  {%- if s.show_hero_bar -%}
    <div class="hero-slider__hero-bar" aria-hidden="true">
      <button class="hero-slider__hero-bar-btn" aria-label="Menu" type="button">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="6" width="13" height="2" rx="1" fill="currentColor"/>
          <rect y="12" width="18" height="2" rx="1" fill="currentColor"/>
        </svg>
      </button>
      <span class="hero-slider__hero-bar-name">{{ s.bar_store_name | default: shop.name | upcase }}</span>
      <a href="/cart" class="hero-slider__hero-bar-btn" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
        </svg>
      </a>
    </div>
  {%- endif -%}

  {%- comment -%} ── Slide track ── {%- endcomment -%}
  <div class="hero-slider__track">
    {%- for block in section.blocks -%}
      {%- assign lines = block.settings.heading | newline_to_br | split: '<br />' -%}

      <div
        class="hero-slider__slide{% if forloop.first %} is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
      >

        {%- comment -%} Layer 1 — background collage / illustration image {%- endcomment -%}
        <div class="hero-slider__media">
          {%- if block.settings.video_url != blank -%}
            {%- if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be' -%}
              {%- if block.settings.video_url contains 'v=' -%}
                {%- assign video_id = block.settings.video_url | split: 'v=' | last | split: '&' | first -%}
              {%- else -%}
                {%- assign video_id = block.settings.video_url | split: '/' | last | split: '?' | first -%}
              {%- endif -%}
              <iframe
                class="hero-slider__video-iframe"
                src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=0&showinfo=0&rel=0"
                allow="autoplay; encrypted-media"
                loading="lazy"
                title="{{ block.settings.heading | escape }}"
              ></iframe>
            {%- elsif block.settings.video_url contains 'vimeo.com' -%}
              {%- assign video_id = block.settings.video_url | split: '/' | last | split: '?' | first -%}
              <iframe
                class="hero-slider__video-iframe"
                src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&background=1"
                allow="autoplay; fullscreen"
                loading="lazy"
                title="{{ block.settings.heading | escape }}"
              ></iframe>
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              srcset="
                {{ block.settings.image | image_url: width: 750 }} 750w,
                {{ block.settings.image | image_url: width: 1200 }} 1200w,
                {{ block.settings.image | image_url: width: 1920 }} 1920w
              "
              sizes="100vw"
              alt="{{ block.settings.image.alt | escape }}"
              class="hero-slider__image"
              {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            {%- assign ph_idx = forloop.index0 | modulo: 3 | plus: 1 -%}
            {{ 'lifestyle-' | append: ph_idx | placeholder_svg_tag: 'hero-slider__placeholder' }}
          {%- endif -%}

          {%- comment -%} Overlay — keeps editorial look even with photos {%- endcomment -%}
          <div
            class="hero-slider__overlay"
            style="--overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
          ></div>
        </div>

        {%- comment -%} Layer 2 — giant editorial typography (behind card) {%- endcomment -%}
        <div class="hero-slider__bg-text" aria-hidden="true">
          {%- for line in lines -%}
            {%- assign clean = line | strip_html | strip -%}
            {%- if clean != blank -%}
              <span class="hero-slider__bg-text-line">{{ clean }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- comment -%} Layer 3 — floating product card (centered, above text) {%- endcomment -%}
        <div
          class="hero-slider__card"
          style="--card-bg: {{ block.settings.card_bg }};"
        >
          {%- if block.settings.card_image != blank -%}
            <img
              src="{{ block.settings.card_image | image_url: width: 600 }}"
              srcset="
                {{ block.settings.card_image | image_url: width: 300 }} 300w,
                {{ block.settings.card_image | image_url: width: 600 }} 600w
              "
              sizes="(max-width: 768px) 180px, 280px"
              alt="{{ block.settings.card_image.alt | default: block.settings.heading | escape }}"
              class="hero-slider__card-img"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="600" height="600"
            >
          {%- else -%}
            <div class="hero-slider__card-placeholder">
              {%- assign pph = forloop.index0 | modulo: 6 | plus: 1 -%}
              {{ 'product-' | append: pph | placeholder_svg_tag: 'hero-slider__card-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} Layer 4 — bottom CTA {%- endcomment -%}
        {%- if block.settings.button_label != blank -%}
          <div class="hero-slider__slide-cta">
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="hero-slider__cta-btn"
            >
              {{ block.settings.button_label }}
            </a>
          </div>
        {%- endif -%}

      </div>{%- comment -%} /.hero-slider__slide {%- endcomment -%}
    {%- endfor -%}
  </div>{%- comment -%} /.hero-slider__track {%- endcomment -%}

  {%- if slide_count > 1 -%}

    <button class="hero-slider__nav hero-slider__nav--prev" aria-label="Previous slide" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="hero-slider__nav hero-slider__nav--next" aria-label="Next slide" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div class="hero-slider__dots" role="tablist" aria-label="Slide navigation">
      {%- for block in section.blocks -%}
        <button
          class="hero-slider__dot{% if forloop.first %} is-active{% endif %}"
          role="tab"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          type="button"
        ></button>
      {%- endfor -%}
    </div>

    {%- if s.autoplay -%}
      <button class="hero-slider__pause" id="SliderPause-{{ section.id }}" aria-label="Pause slideshow" aria-pressed="false" type="button">
        <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      </button>
    {%- endif -%}

  {%- endif -%}
</div>

<script>
(function () {
  var slider = document.getElementById('HeroSlider-{{ section.id }}');
  if (!slider) return;

  var slides   = slider.querySelectorAll('.hero-slider__slide');
  var dots     = slider.querySelectorAll('.hero-slider__dot');
  var prevBtn  = slider.querySelector('.hero-slider__nav--prev');
  var nextBtn  = slider.querySelector('.hero-slider__nav--next');
  var pauseBtn = slider.querySelector('.hero-slider__pause');
  var autoplay = slider.dataset.autoplay === 'true';
  var speed    = parseInt(slider.dataset.autoplaySpeed, 10) || 5000;
  var current  = 0;
  var total    = slides.length;
  var timer    = null;
  var paused   = false;

  if (total <= 1) return;

  function goTo(idx) {
    slides[current].classList.remove('is-active');
    dots[current] && dots[current].classList.remove('is-active');
    dots[current] && dots[current].setAttribute('aria-selected', 'false');
    current = (idx + total) % total;
    slides[current].classList.add('is-active');
    dots[current] && dots[current].classList.add('is-active');
    dots[current] && dots[current].setAttribute('aria-selected', 'true');
  }

  function startTimer() {
    if (!autoplay || paused) return;
    clearInterval(timer);
    timer = setInterval(function () { goTo(current + 1); }, speed);
  }
  function stopTimer() { clearInterval(timer); }

  prevBtn && prevBtn.addEventListener('click', function () { goTo(current - 1); startTimer(); });
  nextBtn && nextBtn.addEventListener('click', function () { goTo(current + 1); startTimer(); });

  dots.forEach(function (dot) {
    dot.addEventListener('click', function () { goTo(parseInt(dot.dataset.index, 10)); startTimer(); });
  });

  if (pauseBtn) {
    pauseBtn.addEventListener('click', function () {
      paused = !paused;
      pauseBtn.setAttribute('aria-pressed', paused ? 'true' : 'false');
      pauseBtn.querySelector('.icon-pause').style.display = paused ? 'none' : '';
      pauseBtn.querySelector('.icon-play').style.display  = paused ? ''     : 'none';
      paused ? stopTimer() : startTimer();
    });
  }

  var touchStartX = 0;
  slider.addEventListener('touchstart', function (e) { touchStartX = e.touches[0].clientX; }, { passive: true });
  slider.addEventListener('touchend', function (e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { goTo(diff > 0 ? current + 1 : current - 1); startTimer(); }
  }, { passive: true });

  slider.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowLeft')  { goTo(current - 1); startTimer(); }
    if (e.key === 'ArrowRight') { goTo(current + 1); startTimer(); }
  });

  slider.addEventListener('mouseenter', stopTimer);
  slider.addEventListener('mouseleave', startTimer);

  if (autoplay) startTimer();
}());
</script>

{% schema %}
{
  "name": "Hero Slider",
  "tag": "section",
  "class": "section-hero-slider",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Slide height",
      "default": 85
    },
    {
      "type": "color",
      "id": "hero_bg",
      "label": "Hero background color",
      "default": "#f5f4f0",
      "info": "Visible when no background image is set"
    },
    {
      "type": "color",
      "id": "hero_text_color",
      "label": "Giant text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Floating top bar"
    },
    {
      "type": "checkbox",
      "id": "show_hero_bar",
      "label": "Show floating navigation bar",
      "default": true
    },
    {
      "type": "text",
      "id": "bar_store_name",
      "label": "Store name in bar",
      "info": "Leave blank to use the shop name automatically"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "select",
      "id": "autoplay_speed",
      "label": "Change slides every",
      "options": [
        { "value": "3000", "label": "3 seconds" },
        { "value": "4000", "label": "4 seconds" },
        { "value": "5000", "label": "5 seconds" },
        { "value": "7000", "label": "7 seconds" },
        { "value": "10000", "label": "10 seconds" }
      ],
      "default": "5000"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Background"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background / collage image"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Background video URL",
          "info": "YouTube or Vimeo URL. Overrides background image."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 60,
          "step": 5,
          "unit": "%",
          "label": "Image overlay opacity",
          "default": 0,
          "info": "Set to 0 for the full editorial look"
        },
        {
          "type": "header",
          "content": "Editorial typography"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Giant heading text",
          "default": "SLIDE\nTITLE",
          "info": "Each line becomes a separate stacked word. Use short words for best results."
        },
        {
          "type": "header",
          "content": "Product card"
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Product card image"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Card background color",
          "default": "#ffffff"
        },
        {
          "type": "header",
          "content": "Call to action"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow (hidden in editorial mode — kept for future use)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "SLIDE\nTITLE",
            "button_label": "Shop Now",
            "overlay_opacity": 0
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "NEW\nDROP",
            "button_label": "Explore",
            "overlay_opacity": 0
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "SOUND\nCRAFTED",
            "button_label": "Discover",
            "overlay_opacity": 0
          }
        }
      ]
    }
  ]
}
{% endschema %}
