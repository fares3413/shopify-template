{%- comment -%} sections/product-hotspots.liquid — Shoppable Product Hotspots {%- endcomment -%}
{%- liquid
  assign s   = section.settings
  assign sid = section.id
-%}

<style>
/* ── Product Hotspots — scoped to section ── */
#ProductHotspots-{{ sid }} {
  --phs-card-bg:        {{ s.card_bg }};
  --phs-section-bg:     {{ s.section_bg }};
  --phs-text:           {{ s.text_color }};
  --phs-text-muted:     {{ s.text_muted_color }};
  --phs-hotspot-color:  {{ s.hotspot_color }};
  --phs-accent:         var(--color-accent, #c9a96e);
  --phs-radius:         var(--radius-lg, 16px);
  --phs-shadow:         var(--shadow-lg, 0 8px 32px rgba(0,0,0,0.14));
  --phs-transition:     0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

#ProductHotspots-{{ sid }} .phs__inner {
  max-width: var(--page-width, 1320px);
  margin: 0 auto;
  padding: 0 var(--gutter, 2rem);
}

/* Header */
#ProductHotspots-{{ sid }} .phs__header {
  text-align: center;
  margin-bottom: 3rem;
}
#ProductHotspots-{{ sid }} .phs__subheading {
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--phs-accent);
  margin: 0 0 0.5rem;
}
#ProductHotspots-{{ sid }} .phs__heading {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 700;
  color: var(--phs-text);
  margin: 0;
  line-height: 1.2;
}

/* 2-column layout */
#ProductHotspots-{{ sid }} .phs__layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 2rem;
  align-items: stretch;
  min-height: 560px;
}

/* ── IMAGE COLUMN ── */
#ProductHotspots-{{ sid }} .phs__image-wrap {
  position: relative;
  border-radius: var(--phs-radius);
  overflow: hidden;
  background: var(--color-bg-soft, #f5f5f3);
  box-shadow: var(--phs-shadow);
}
#ProductHotspots-{{ sid }} .phs__lifestyle-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
#ProductHotspots-{{ sid }} .phs__lifestyle-placeholder {
  width: 100%;
  height: 100%;
  min-height: 520px;
  display: flex;
  align-items: center;
  justify-content: center;
}
#ProductHotspots-{{ sid }} .phs__lifestyle-placeholder svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ── HOTSPOT MARKERS ── */
#ProductHotspots-{{ sid }} .phs__hotspot {
  position: absolute;
  width: 36px;
  height: 36px;
  transform: translate(-50%, -50%);
  background: var(--phs-hotspot-color);
  border: 2.5px solid rgba(255,255,255,0.9);
  border-radius: 50%;
  cursor: pointer;
  z-index: 2;
  box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  transition: transform var(--phs-transition), box-shadow var(--phs-transition), background var(--phs-transition);
  display: flex;
  align-items: center;
  justify-content: center;
}
#ProductHotspots-{{ sid }} .phs__hotspot::after {
  content: '';
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--phs-accent);
  transition: transform var(--phs-transition);
}
/* Ripple ring */
#ProductHotspots-{{ sid }} .phs__hotspot-ring {
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.5);
  animation: phs-ring-pulse 2.2s ease-out infinite;
  opacity: 0;
  pointer-events: none;
}
@keyframes phs-ring-pulse {
  0%   { transform: scale(0.75); opacity: 0.7; }
  100% { transform: scale(1.5);  opacity: 0; }
}
#ProductHotspots-{{ sid }} .phs__hotspot:hover {
  transform: translate(-50%, -50%) scale(1.15);
  box-shadow: 0 4px 20px rgba(0,0,0,0.35);
}
#ProductHotspots-{{ sid }} .phs__hotspot:focus-visible {
  outline: 3px solid var(--phs-accent);
  outline-offset: 3px;
}
#ProductHotspots-{{ sid }} .phs__hotspot.is-active {
  background: var(--phs-accent);
  border-color: #fff;
  transform: translate(-50%, -50%) scale(1.2);
  box-shadow: 0 4px 24px rgba(201,169,110,0.5);
}
#ProductHotspots-{{ sid }} .phs__hotspot.is-active::after {
  background: #fff;
}

/* Marker label tooltip */
#ProductHotspots-{{ sid }} .phs__hotspot-label {
  position: absolute;
  bottom: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background: rgba(26,26,26,0.92);
  color: #fff;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  white-space: nowrap;
  padding: 0.3rem 0.65rem;
  border-radius: var(--radius-full, 9999px);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s ease;
  backdrop-filter: blur(4px);
}
#ProductHotspots-{{ sid }} .phs__hotspot:hover .phs__hotspot-label,
#ProductHotspots-{{ sid }} .phs__hotspot:focus-visible .phs__hotspot-label,
#ProductHotspots-{{ sid }} .phs__hotspot.is-active .phs__hotspot-label {
  opacity: 1;
}

/* ── PRODUCT CARD COLUMN ── */
#ProductHotspots-{{ sid }} .phs__card-wrap {
  background: var(--phs-card-bg);
  border-radius: var(--phs-radius);
  box-shadow: var(--phs-shadow);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* Individual cards (stacked, show only active) */
#ProductHotspots-{{ sid }} .phs__card {
  display: flex;
  flex-direction: column;
  flex: 1;
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transform: translateY(10px);
  transition: opacity var(--phs-transition), transform var(--phs-transition);
}
#ProductHotspots-{{ sid }} .phs__card.is-active {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
  position: relative;
  flex: 1;
}

/* Card image */
#ProductHotspots-{{ sid }} .phs__card-img-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  flex-shrink: 0;
}
#ProductHotspots-{{ sid }} .phs__card-img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  padding: 1.5rem;
  transition: transform 0.5s ease;
}
#ProductHotspots-{{ sid }} .phs__card-img:hover {
  transform: scale(1.04);
}
#ProductHotspots-{{ sid }} .phs__card-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  background: #f0f0ee;
}
#ProductHotspots-{{ sid }} .phs__card-img-placeholder svg,
#ProductHotspots-{{ sid }} .phs__placeholder-svg {
  width: 100%;
  max-width: 220px;
  height: auto;
  opacity: 0.4;
}

/* Card info */
#ProductHotspots-{{ sid }} .phs__card-info {
  padding: 1.5rem 1.75rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}
#ProductHotspots-{{ sid }} .phs__card-vendor {
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--phs-text-muted);
  margin: 0;
}
#ProductHotspots-{{ sid }} .phs__card-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--phs-text);
  margin: 0;
  line-height: 1.3;
}
#ProductHotspots-{{ sid }} .phs__card-price {
  font-size: 1.0625rem;
  font-weight: 600;
  color: var(--phs-text);
  margin: 0;
}
#ProductHotspots-{{ sid }} .phs__card-price s {
  color: var(--phs-text-muted);
  font-weight: 400;
  margin-left: 0.4em;
}
#ProductHotspots-{{ sid }} .phs__card-desc {
  font-size: 0.875rem;
  line-height: 1.6;
  color: var(--phs-text-muted);
  margin: 0.25rem 0 0;
}
#ProductHotspots-{{ sid }} .phs__card-btn {
  display: inline-block;
  margin-top: auto;
  padding: 0.75rem 1.5rem;
  background: var(--color-primary, #1a1a1a);
  color: #fff;
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-decoration: none;
  border-radius: var(--radius-full, 9999px);
  text-align: center;
  transition: background var(--transition, 0.25s ease), transform 0.2s ease, box-shadow 0.2s ease;
  border: none;
  cursor: pointer;
  align-self: flex-start;
}
#ProductHotspots-{{ sid }} .phs__card-btn:hover {
  background: var(--phs-accent);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(201,169,110,0.35);
}

/* Dot navigation */
#ProductHotspots-{{ sid }} .phs__dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 1.75rem 1.5rem;
  flex-shrink: 0;
}
#ProductHotspots-{{ sid }} .phs__dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: none;
  background: var(--color-border, #e8e8e8);
  cursor: pointer;
  padding: 0;
  transition: background var(--phs-transition), transform var(--phs-transition);
}
#ProductHotspots-{{ sid }} .phs__dot.is-active {
  background: var(--phs-accent);
  transform: scale(1.4);
}
#ProductHotspots-{{ sid }} .phs__dot:focus-visible {
  outline: 2px solid var(--phs-accent);
  outline-offset: 2px;
}

/* Empty state */
#ProductHotspots-{{ sid }} .phs__empty {
  padding: 3rem 2rem;
  text-align: center;
  color: var(--phs-text-muted);
  font-size: 0.9rem;
}

/* ── MOBILE ── */
@media (max-width: 768px) {
  #ProductHotspots-{{ sid }} .phs__layout {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto;
    min-height: unset;
  }
  /* Image first on mobile */
  #ProductHotspots-{{ sid }} .phs__image-wrap {
    order: 1;
    min-height: 300px;
    max-height: 56vw;
  }
  #ProductHotspots-{{ sid }} .phs__card-wrap {
    order: 2;
  }
  #ProductHotspots-{{ sid }} .phs__card-img-wrap {
    aspect-ratio: 4 / 3;
  }
  #ProductHotspots-{{ sid }} .phs__hotspot {
    width: 30px;
    height: 30px;
  }
}
@media (max-width: 480px) {
  #ProductHotspots-{{ sid }} .phs__card-info {
    padding: 1.25rem;
  }
  #ProductHotspots-{{ sid }} .phs__card-title {
    font-size: 1.0625rem;
  }
}
</style>

<section
  class="product-hotspots-section section-padding"
  id="ProductHotspots-{{ sid }}"
  style="background: {{ s.section_bg }};"
>
  <div class="phs__inner">

    {%- if s.heading != blank or s.subheading != blank -%}
      <div class="phs__header">
        {%- if s.subheading != blank -%}
          <p class="phs__subheading">{{ s.subheading | escape }}</p>
        {%- endif -%}
        {%- if s.heading != blank -%}
          <h2 class="phs__heading">{{ s.heading | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="phs__layout">

      {%- comment -%} ── LEFT: lifestyle image with hotspot markers ── {%- endcomment -%}
      <div class="phs__image-wrap">
        {%- if s.lifestyle_image != blank -%}
          <img
            src="{{ s.lifestyle_image | image_url: width: 1400 }}"
            srcset="
              {{ s.lifestyle_image | image_url: width: 600 }} 600w,
              {{ s.lifestyle_image | image_url: width: 900 }} 900w,
              {{ s.lifestyle_image | image_url: width: 1400 }} 1400w
            "
            sizes="(max-width: 768px) 100vw, 60vw"
            alt="{{ s.lifestyle_image.alt | default: s.heading | escape }}"
            class="phs__lifestyle-img"
            width="{{ s.lifestyle_image.width }}"
            height="{{ s.lifestyle_image.height }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="phs__lifestyle-placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- assign bprod = all_products[block.settings.product] -%}
          {%- assign aria_lbl = bprod.title | default: block.settings.label | default: 'Hotspot' -%}
          <button
            class="phs__hotspot{% if forloop.first %} is-active{% endif %}"
            style="left: {{ block.settings.pos_x }}%; top: {{ block.settings.pos_y }}%;"
            data-block="{{ block.id }}"
            aria-label="{{ aria_lbl | escape }}"
            aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
            type="button"
            {{ block.shopify_attributes }}
          >
            <span class="phs__hotspot-ring" aria-hidden="true"></span>
            {%- if block.settings.label != blank -%}
              <span class="phs__hotspot-label" aria-hidden="true">{{ block.settings.label | escape }}</span>
            {%- endif -%}
          </button>
        {%- endfor -%}
      </div>

      {%- comment -%} ── RIGHT: product card ── {%- endcomment -%}
      <div class="phs__card-wrap">

        {%- for block in section.blocks -%}
          {%- assign bprod = all_products[block.settings.product] -%}
          {%- assign card_image = block.settings.custom_image | default: bprod.featured_image -%}

          <div
            class="phs__card{% if forloop.first %} is-active{% endif %}"
            id="PhsCard-{{ sid }}-{{ block.id }}"
            data-block="{{ block.id }}"
            role="tabpanel"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- comment -%} Product image {%- endcomment -%}
            <div class="phs__card-img-wrap">
              {%- if card_image != blank -%}
                <img
                  src="{{ card_image | image_url: width: 600 }}"
                  srcset="
                    {{ card_image | image_url: width: 380 }} 380w,
                    {{ card_image | image_url: width: 600 }} 600w,
                    {{ card_image | image_url: width: 760 }} 760w
                  "
                  sizes="(max-width: 768px) 100vw, 380px"
                  alt="{{ card_image.alt | default: bprod.title | escape }}"
                  class="phs__card-img"
                  width="600"
                  height="600"
                  loading="lazy"
                >
              {%- else -%}
                <div class="phs__card-img-placeholder">
                  {%- assign ph_idx = forloop.index0 | modulo: 6 | plus: 1 -%}
                  {{ 'product-' | append: ph_idx | placeholder_svg_tag: 'phs__placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            {%- comment -%} Product info {%- endcomment -%}
            <div class="phs__card-info">
              {%- if bprod != blank -%}

                {%- if bprod.vendor != blank -%}
                  <p class="phs__card-vendor">{{ bprod.vendor | escape }}</p>
                {%- endif -%}

                <h3 class="phs__card-title">{{ bprod.title | escape }}</h3>

                <p class="phs__card-price">
                  {%- if bprod.compare_at_price > bprod.price -%}
                    <s>{{ bprod.compare_at_price | money }}</s>
                  {%- endif -%}
                  {{ bprod.price | money }}
                </p>

                {%- if s.show_description and bprod.description != blank -%}
                  <p class="phs__card-desc">
                    {{ bprod.description | strip_html | truncate: 130 }}
                  </p>
                {%- endif -%}

                <a
                  href="{{ bprod.url }}"
                  class="phs__card-btn"
                  aria-label="{{ s.btn_label | escape }}: {{ bprod.title | escape }}"
                >
                  {{ s.btn_label | escape }}
                </a>

              {%- else -%}

                <p class="phs__card-vendor">VENDOR</p>
                <h3 class="phs__card-title">Example product</h3>
                <p class="phs__card-price">{{ 1999 | money }}</p>
                {%- if s.show_description -%}
                  <p class="phs__card-desc">Add a product to this hotspot in the theme editor to see it here.</p>
                {%- endif -%}
                <a href="#" class="phs__card-btn">{{ s.btn_label | escape }}</a>

              {%- endif -%}
            </div>
          </div>

        {%- else -%}
          <div class="phs__empty">
            Add hotspot blocks in the Theme Editor to get started.
          </div>
        {%- endfor -%}

        {%- if section.blocks.size > 1 -%}
          <div class="phs__dots" role="tablist" aria-label="Select product">
            {%- for block in section.blocks -%}
              <button
                class="phs__dot{% if forloop.first %} is-active{% endif %}"
                data-block="{{ block.id }}"
                role="tab"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                aria-controls="PhsCard-{{ sid }}-{{ block.id }}"
                aria-label="Product {{ forloop.index }}"
                type="button"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>{%- comment -%} /.phs__card-wrap {%- endcomment -%}

    </div>{%- comment -%} /.phs__layout {%- endcomment -%}
  </div>{%- comment -%} /.phs__inner {%- endcomment -%}
</section>

<script>
(function () {
  'use strict';

  var section = document.getElementById('ProductHotspots-{{ sid }}');
  if (!section) return;

  /**
   * Activate a hotspot/card by block ID.
   * Handles hotspot markers, product cards, and dot nav simultaneously.
   */
  function activate(blockId) {
    // Hotspot markers
    section.querySelectorAll('.phs__hotspot').forEach(function (btn) {
      var on = btn.dataset.block === blockId;
      btn.classList.toggle('is-active', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
    });

    // Product cards
    section.querySelectorAll('.phs__card').forEach(function (card) {
      var on = card.dataset.block === blockId;
      card.classList.toggle('is-active', on);
      card.setAttribute('aria-hidden', on ? 'false' : 'true');
    });

    // Dot navigation
    section.querySelectorAll('.phs__dot').forEach(function (dot) {
      var on = dot.dataset.block === blockId;
      dot.classList.toggle('is-active', on);
      dot.setAttribute('aria-selected', on ? 'true' : 'false');
    });
  }

  // Hotspot marker clicks
  section.querySelectorAll('.phs__hotspot').forEach(function (btn) {
    btn.addEventListener('click', function () {
      activate(btn.dataset.block);
    });
  });

  // Dot nav clicks
  section.querySelectorAll('.phs__dot').forEach(function (dot) {
    dot.addEventListener('click', function () {
      activate(dot.dataset.block);
    });
  });

  // Keyboard navigation between hotspots (arrow keys cycle through markers)
  var hotspots = Array.from(section.querySelectorAll('.phs__hotspot'));
  hotspots.forEach(function (btn, idx) {
    btn.addEventListener('keydown', function (e) {
      var next = null;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        next = hotspots[(idx + 1) % hotspots.length];
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        next = hotspots[(idx - 1 + hotspots.length) % hotspots.length];
      }
      if (next) {
        next.focus();
        activate(next.dataset.block);
      }
    });
  });

})();
</script>

{% schema %}
{
  "name": "Product Hotspots",
  "tag": "section",
  "class": "product-hotspots-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the Look"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow / subheading",
      "default": "Premium Speakers"
    },
    {
      "type": "image_picker",
      "id": "lifestyle_image",
      "label": "Lifestyle image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#f5f5f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_muted_color",
      "label": "Muted text color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "hotspot_color",
      "label": "Hotspot marker color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card options"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Horizontal position (%)",
          "min": 2,
          "max": 98,
          "step": 1,
          "default": 30
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Vertical position (%)",
          "min": 2,
          "max": 98,
          "step": 1,
          "default": 40
        },
        {
          "type": "text",
          "id": "label",
          "label": "Marker label (optional tooltip)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom product image override"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Hotspots",
      "blocks": [
        { "type": "hotspot", "settings": { "pos_x": 28, "pos_y": 38 } },
        { "type": "hotspot", "settings": { "pos_x": 60, "pos_y": 52 } },
        { "type": "hotspot", "settings": { "pos_x": 43, "pos_y": 72 } }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
