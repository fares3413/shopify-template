<section class="cart-page section-padding">
  <div class="page-width page-width--narrow">
    <h1 class="cart-page__title">Your Cart</h1>
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post">
        {%- for item in cart.items -%}
          <div class="cart-page__item">
            <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" width="80" height="80">
            <div class="cart-page__item-details">
              <a href="{{ item.url }}">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <span>{{ item.variant.title }}</span>
              {%- endunless -%}
              <div class="cart-page__item-qty">
                <input type="number" name="updates[]" value="{{ item.quantity }}" min="1" data-index="{{ forloop.index0 }}">
              </div>
            </div>
            <span class="cart-page__item-price">{{ item.line_price | money }}</span>
          </div>
        {%- endfor -%}
        <div class="cart-page__footer">
          <div class="cart-page__total">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p>Taxes and shipping calculated at checkout.</p>
          <button type="submit" name="update" class="btn btn--outline btn--full">Update cart</button>
          <a href="/checkout" class="btn btn--primary btn--full">Checkout</a>
        </div>
      </form>
    {%- else -%}
      <p>Your cart is empty.</p>
      <a href="{{ routes.collections_url }}" class="btn btn--primary">Continue shopping</a>
    {%- endif -%}
  </div>
</section>
{% schema %}{"name":"Cart","presets":[{"name":"Cart"}]}{% endschema %}
