{%- assign s = section.settings -%}
{%- assign sid = section.id -%}

<style>
/* ── Image Carousel — scoped ── */
#ImgCarousel-{{ sid }} {
  --ic-bg:      {{ s.bg_color }};
  --ic-text:    {{ s.text_color }};
  --ic-gap:     {{ s.card_gap }}px;
  --ic-width:   {{ s.card_width }}px;
  --ic-speed:   {{ s.speed }}s;
  background:   var(--ic-bg);
  padding: 5rem 0;
  overflow: hidden;
}

/* Header */
#ImgCarousel-{{ sid }} .ic__header {
  max-width: var(--page-width, 1320px);
  margin: 0 auto 3rem;
  padding: 0 var(--gutter, 2rem);
}
#ImgCarousel-{{ sid }} .ic__eyebrow {
  font-size: var(--text-xs);
  font-weight: var(--fw-bold);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-accent, #c9a96e);
  margin: 0 0 0.75rem;
}
#ImgCarousel-{{ sid }} .ic__heading {
  font-size: clamp(1.75rem, 3.5vw, 3rem);
  font-weight: 800;
  color: var(--ic-text);
  margin: 0 0 1rem;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
#ImgCarousel-{{ sid }} .ic__desc {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--ic-text);
  opacity: 0.6;
  max-width: 560px;
  margin: 0;
}

/* Track */
#ImgCarousel-{{ sid }} .ic__track-wrap {
  overflow: hidden;
  /* Fade edges */
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  mask-image:         linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
}
#ImgCarousel-{{ sid }} .ic__track {
  display: flex;
  gap: var(--ic-gap);
  width: max-content;
  animation: ic-scroll var(--ic-speed) linear infinite;
  will-change: transform;
}
#ImgCarousel-{{ sid }} .ic__track.is-paused {
  animation-play-state: paused;
}
@keyframes ic-scroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* Cards — 3D Tilt + Glassmorphism */
#ImgCarousel-{{ sid }} .ic__card {
  /* 3D tilt state variables (updated by JS) */
  --tilt-x:   0deg;
  --tilt-y:   0deg;
  --glare-x:  50%;
  --glare-y:  50%;

  flex-shrink: 0;
  width: var(--ic-width);
  border-radius: 20px;
  overflow: hidden;
  position: relative;

  /* Glassmorphism — crisp white + light edge + depth */
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.55);
  box-shadow:
    0 4px 24px rgba(0, 0, 0, 0.06),
    0 1px 0 rgba(255, 255, 255, 0.7) inset;

  /* 3D perspective applied here */
  transform:
    perspective(700px)
    rotateX(var(--tilt-x))
    rotateY(var(--tilt-y))
    scale(1);
  transform-style: preserve-3d;
  transition:
    transform 0.08s ease-out,
    box-shadow 0.35s var(--ease-component);
  will-change: transform;
  cursor: pointer;
}

/* Glare overlay */
#ImgCarousel-{{ sid }} .ic__card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: radial-gradient(
    circle at var(--glare-x) var(--glare-y),
    rgba(255, 255, 255, 0.28) 0%,
    rgba(255, 255, 255, 0.04) 55%,
    transparent 70%
  );
  opacity: 0;
  transition: opacity 0.2s ease;
  pointer-events: none;
  z-index: 3;
  mix-blend-mode: overlay;
}

#ImgCarousel-{{ sid }} .ic__card.is-tilting::before {
  opacity: 1;
}

/* Hover shadow bloom */
#ImgCarousel-{{ sid }} .ic__card.is-tilting {
  box-shadow:
    0 20px 48px rgba(0, 0, 0, 0.14),
    0 4px 12px rgba(0, 0, 0, 0.08),
    0 1px 0 rgba(255, 255, 255, 0.7) inset;
}

#ImgCarousel-{{ sid }} .ic__card-img-wrap {
  width: 100%;
  {%- if s.image_ratio == 'square' -%}
  aspect-ratio: 1 / 1;
  {%- elsif s.image_ratio == 'portrait' -%}
  aspect-ratio: 3 / 4;
  {%- else -%}
  aspect-ratio: 4 / 3;
  {%- endif -%}
  overflow: hidden;
}

#ImgCarousel-{{ sid }} .ic__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s var(--ease-component);
}

#ImgCarousel-{{ sid }} .ic__card.is-tilting .ic__card-img {
  transform: scale(1.04) translateZ(20px);
}
#ImgCarousel-{{ sid }} .ic__card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted, #ebebeb);
}
#ImgCarousel-{{ sid }} .ic__card-placeholder svg {
  width: 48px;
  height: 48px;
  opacity: 0.25;
}
#ImgCarousel-{{ sid }} .ic__card-label {
  padding: 1rem 1.25rem;
  font-size: var(--text-base);
  font-weight: var(--fw-semibold);
  color: var(--ic-text);
  letter-spacing: -0.01em;
}

/* 3D tilt — no animations for reduced motion */
@media (prefers-reduced-motion: reduce) {
  #ImgCarousel-{{ sid }} .ic__card {
    transition: box-shadow 0.35s ease;
    transform: none !important;
  }
  #ImgCarousel-{{ sid }} .ic__card::before { display: none; }
  #ImgCarousel-{{ sid }} .ic__track { animation: none !important; }
}

@media (max-width: 768px) {
  #ImgCarousel-{{ sid }} {
    --ic-width: {{ s.card_width | times: 0.7 | round }}px;
    padding: 3.5rem 0;
  }
}
</style>

<div id="ImgCarousel-{{ sid }}">

  {%- if s.eyebrow != blank or s.heading != blank or s.description != blank -%}
    <div class="ic__header">
      {%- if s.eyebrow != blank -%}
        <p class="ic__eyebrow">{{ s.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="ic__heading">{{ s.heading | escape }}</h2>
      {%- endif -%}
      {%- if s.description != blank -%}
        <p class="ic__desc">{{ s.description | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ic__track-wrap">
    <div
      class="ic__track"
      id="IcTrack-{{ sid }}"
      style="gap: {{ s.card_gap }}px;"
    >
      {%- comment -%} Real items {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="ic__card" {{ block.shopify_attributes }}>
          <div class="ic__card-img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
                class="ic__card-img"
                loading="lazy"
                width="800" height="800"
              >
            {%- else -%}
              <div class="ic__card-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <p class="ic__card-label">{{ block.settings.label | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- comment -%} Duplicate for seamless loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="ic__card" aria-hidden="true">
          <div class="ic__card-img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt=""
                class="ic__card-img"
                loading="lazy"
                width="800" height="800"
              >
            {%- else -%}
              <div class="ic__card-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              </div>
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <p class="ic__card-label">{{ block.settings.label | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

</div>

<script>
(function () {
  var wrap  = document.getElementById('ImgCarousel-{{ sid }}');
  var track = document.getElementById('IcTrack-{{ sid }}');
  if (!wrap || !track) return;

  /* ── Pause on hover ── */
  {% if s.pause_on_hover -%}
  wrap.addEventListener('mouseenter', function () { track.classList.add('is-paused'); });
  wrap.addEventListener('mouseleave', function () { track.classList.remove('is-paused'); });
  {%- endif %}

  /* ── 3D Tilt per card ── */
  var MAX_TILT = 12; // degrees

  function applyTilt(card, e) {
    var rect  = card.getBoundingClientRect();
    var x     = (e.clientX || (e.touches && e.touches[0].clientX)) - rect.left;
    var y     = (e.clientY || (e.touches && e.touches[0].clientY)) - rect.top;
    var cx    = rect.width  / 2;
    var cy    = rect.height / 2;
    var rotX  = ((y - cy) / cy) * -MAX_TILT;
    var rotY  = ((x - cx) / cx) *  MAX_TILT;
    card.style.setProperty('--tilt-x',   rotX.toFixed(2) + 'deg');
    card.style.setProperty('--tilt-y',   rotY.toFixed(2) + 'deg');
    card.style.setProperty('--glare-x',  ((x / rect.width)  * 100).toFixed(1) + '%');
    card.style.setProperty('--glare-y',  ((y / rect.height) * 100).toFixed(1) + '%');
    card.classList.add('is-tilting');
  }

  function resetTilt(card) {
    card.style.setProperty('--tilt-x', '0deg');
    card.style.setProperty('--tilt-y', '0deg');
    card.classList.remove('is-tilting');
  }

  /* Only observe REAL cards (not aria-hidden duplicates) */
  wrap.querySelectorAll('.ic__card:not([aria-hidden])').forEach(function (card) {
    card.addEventListener('mousemove',  function (e) { applyTilt(card, e); });
    card.addEventListener('touchmove',  function (e) { applyTilt(card, e); }, { passive: true });
    card.addEventListener('mouseleave', function ()  { resetTilt(card); });
    card.addEventListener('touchend',   function ()  { resetTilt(card); });
  });

  /* Respect prefers-reduced-motion */
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    wrap.querySelectorAll('.ic__card').forEach(function (c) {
      c.removeEventListener('mousemove', applyTilt);
    });
  }
}());
</script>

{% schema %}
{
  "name": "Image Carousel",
  "tag": "section",
  "class": "section-image-carousel",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width (px)",
      "min": 180,
      "max": 480,
      "step": 20,
      "default": 300
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 20
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square",   "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "landscape","label": "Landscape (4:3)" }
      ],
      "default": "portrait"
    },
    {
      "type": "header",
      "content": "Motion"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed (seconds for full loop)",
      "min": 8,
      "max": 60,
      "step": 2,
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#f5f4f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (optional)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Carousel",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
