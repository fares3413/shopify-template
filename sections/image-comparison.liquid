{%- liquid
  assign layout       = section.settings.layout | default: 'horizontal'
  assign heading_tag  = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'md'
  assign heading_align = section.settings.heading_alignment | default: 'center'
  assign start_pos    = section.settings.start_position | default: '50'
-%}

<style>
  @media (max-width: 768px) {
    #ICContainer-{{ section.id }} { height: {{ section.settings.mobile_height | default: '320px' }} !important; }
  }
</style>

<section class="ic-section" id="ImageComparison-{{ section.id }}">
  <div class="page-width">

    <!-- Header -->
    {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="ic-header ic-header--{{ heading_align }}">
        {%- if section.settings.subheading != blank -%}
          <p class="ic-header__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="ic-header__heading ic-header__heading--{{ heading_size }}">
            {{- section.settings.heading -}}
          </{{ heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="ic-header__desc">{{ section.settings.description }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--primary ic-header__btn">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Comparison area -->
    <div
      class="ic-container ic-container--{{ layout }}"
      id="ICContainer-{{ section.id }}"
      role="img"
      aria-label="{{ section.settings.heading | default: 'Image comparison' | escape }}"
      style="--ic-pos: {{ start_pos }}%; height: {{ section.settings.desktop_height | default: '600px' }};"
    >
      <!-- Before image (left / top) -->
      <div class="ic-before">
        {%- if section.settings.image_before != blank -%}
          <img
            src="{{ section.settings.image_before | image_url: width: 1600 }}"
            alt="{{ section.settings.image_before.alt | default: section.settings.label_before | escape }}"
            class="ic-img"
            loading="lazy"
            draggable="false"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'ic-img ic-placeholder' }}
        {%- endif -%}
        {%- if section.settings.label_before != blank or section.settings.sublabel_before != blank -%}
          <div class="ic-label ic-label--before">
            {%- if section.settings.sublabel_before != blank -%}
              <span class="ic-label__sub">{{ section.settings.sublabel_before }}</span>
            {%- endif -%}
            {%- if section.settings.label_before != blank -%}
              <span class="ic-label__main">{{ section.settings.label_before }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- After image (right / bottom) -->
      <div class="ic-after">
        {%- if section.settings.image_after != blank -%}
          <img
            src="{{ section.settings.image_after | image_url: width: 1600 }}"
            alt="{{ section.settings.image_after.alt | default: section.settings.label_after | escape }}"
            class="ic-img"
            loading="lazy"
            draggable="false"
          >
        {%- else -%}
          {{ 'collection-2' | placeholder_svg_tag: 'ic-img ic-placeholder' }}
        {%- endif -%}
        {%- if section.settings.label_after != blank or section.settings.sublabel_after != blank -%}
          <div class="ic-label ic-label--after">
            {%- if section.settings.sublabel_after != blank -%}
              <span class="ic-label__sub">{{ section.settings.sublabel_after }}</span>
            {%- endif -%}
            {%- if section.settings.label_after != blank -%}
              <span class="ic-label__main">{{ section.settings.label_after }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Drag handle -->
      <div class="ic-handle" id="ICHandle-{{ section.id }}" aria-hidden="true">
        {%- if layout == 'horizontal' -%}
          <div class="ic-handle__line"></div>
          <div class="ic-handle__knob">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor" aria-hidden="true">
              <rect x="3"  y="3" width="2.5" height="16" rx="1.25"/>
              <rect x="9.75" y="3" width="2.5" height="16" rx="1.25"/>
              <rect x="16.5" y="3" width="2.5" height="16" rx="1.25"/>
            </svg>
          </div>
          <div class="ic-handle__line"></div>
        {%- else -%}
          <div class="ic-handle__line"></div>
          <div class="ic-handle__knob">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="currentColor" aria-hidden="true">
              <rect x="3" y="3"    width="16" height="2.5" rx="1.25"/>
              <rect x="3" y="9.75" width="16" height="2.5" rx="1.25"/>
              <rect x="3" y="16.5" width="16" height="2.5" rx="1.25"/>
            </svg>
          </div>
          <div class="ic-handle__line"></div>
        {%- endif -%}
      </div>

    </div><!-- /.ic-container -->
  </div>
</section>

<script>
(function () {
  var container   = document.getElementById('ICContainer-{{ section.id }}');
  if (!container) return;

  var isHorizontal = {{ section.settings.layout | default: 'horizontal' | json }} === 'horizontal';
  var dragging = false;

  function clamp(v, lo, hi) { return Math.min(Math.max(v, lo), hi); }

  function setPos(e) {
    var rect   = container.getBoundingClientRect();
    var client = e.touches ? e.touches[0] : e;
    var pct;
    if (isHorizontal) {
      pct = (client.clientX - rect.left) / rect.width * 100;
    } else {
      pct = (client.clientY - rect.top) / rect.height * 100;
    }
    container.style.setProperty('--ic-pos', clamp(pct, 2, 98) + '%');
  }

  /* Drag start */
  container.addEventListener('mousedown',  function (e) { dragging = true; setPos(e); e.preventDefault(); });
  container.addEventListener('touchstart', function (e) { dragging = true; setPos(e); e.preventDefault(); }, { passive: false });

  /* Drag move */
  document.addEventListener('mousemove',  function (e) { if (dragging) { setPos(e); e.preventDefault(); } });
  document.addEventListener('touchmove',  function (e) { if (dragging) { setPos(e); e.preventDefault(); } }, { passive: false });

  /* Drag end */
  document.addEventListener('mouseup',  function () { dragging = false; });
  document.addEventListener('touchend', function () { dragging = false; });

  /* Keyboard support on the handle */
  var handle = document.getElementById('ICHandle-{{ section.id }}');
  if (handle) {
    handle.setAttribute('tabindex', '0');
    handle.setAttribute('role', 'slider');
    handle.setAttribute('aria-valuemin', '0');
    handle.setAttribute('aria-valuemax', '100');
    handle.setAttribute('aria-valuenow', '{{ start_pos }}');
    handle.addEventListener('keydown', function (e) {
      var cur = parseFloat(container.style.getPropertyValue('--ic-pos')) || {{ start_pos }};
      var step = e.shiftKey ? 10 : 2;
      if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { container.style.setProperty('--ic-pos', clamp(cur - step, 2, 98) + '%'); e.preventDefault(); }
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown')  { container.style.setProperty('--ic-pos', clamp(cur + step, 2, 98) + '%'); e.preventDefault(); }
    });
  }
}());
</script>

{% schema %}
{
  "name": "Image Comparison",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "vertical",   "label": "Vertical" }
      ],
      "default": "horizontal"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop height",
      "options": [
        { "value": "400px",  "label": "400px" },
        { "value": "500px",  "label": "500px" },
        { "value": "600px",  "label": "600px" },
        { "value": "750px",  "label": "750px" },
        { "value": "900px",  "label": "900px" },
        { "value": "100vh",  "label": "Full screen" }
      ],
      "default": "600px"
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "Mobile height",
      "options": [
        { "value": "250px", "label": "250px" },
        { "value": "320px", "label": "320px" },
        { "value": "400px", "label": "400px" },
        { "value": "500px", "label": "500px" }
      ],
      "default": "320px"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "info": "Specify heading code types for SEO and search engines for crawling purposes.",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave the label blank to hide the button."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Before image (left / top)"
    },
    {
      "type": "image_picker",
      "id": "image_before",
      "label": "Before image"
    },
    {
      "type": "text",
      "id": "sublabel_before",
      "label": "Sub-label",
      "default": "Flow Harmony"
    },
    {
      "type": "text",
      "id": "label_before",
      "label": "Label",
      "default": "Gold Tone"
    },
    {
      "type": "header",
      "content": "After image (right / bottom)"
    },
    {
      "type": "image_picker",
      "id": "image_after",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "sublabel_after",
      "label": "Sub-label",
      "default": "Flow Harmony"
    },
    {
      "type": "text",
      "id": "label_after",
      "label": "Label",
      "default": "Crimson Shadow"
    },
    {
      "type": "header",
      "content": "Divider start position"
    },
    {
      "type": "select",
      "id": "start_position",
      "label": "Initial divider position",
      "options": [
        { "value": "30", "label": "30%" },
        { "value": "40", "label": "40%" },
        { "value": "50", "label": "50% (center)" },
        { "value": "60", "label": "60%" },
        { "value": "70", "label": "70%" }
      ],
      "default": "50"
    }
  ],
  "presets": [
    {
      "name": "Image Comparison",
      "settings": {
        "heading": "Vibrant Headphone Choices",
        "subheading": "Sound in Spectrum",
        "sublabel_before": "Flow Harmony",
        "label_before": "Gold Tone",
        "sublabel_after": "Flow Harmony",
        "label_after": "Crimson Shadow"
      }
    }
  ]
}
{% endschema %}
