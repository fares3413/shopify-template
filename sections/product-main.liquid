<script>
(function () {
  var sectionId      = '{{ section.id }}';
  var productData    = {{ product.variants | json }};
  var moneyFormat    = {{ shop.money_format | json }};

  /* ── Helpers ── */
  function formatMoney(cents) {
    return moneyFormat.replace('{{amount}}', (cents / 100).toFixed(2))
                      .replace('{{amount_no_decimals}}', Math.round(cents / 100))
                      .replace('{{amount_with_comma_separator}}', (cents / 100).toFixed(2).replace('.', ','));
  }

  /* ── Element refs ── */
  var variantSelector  = document.getElementById('ProductVariantSelector-' + sectionId);
  var mainImage        = document.getElementById('MainProductImage-' + sectionId);
  var priceEl          = document.querySelector('#ProductPage-' + sectionId + ' [data-regular-price]');
  var priceWrap        = document.getElementById('ProductPrice-' + sectionId);
  var skuEl            = document.querySelector('#ProductSku-' + sectionId + ' [data-sku]');
  var skuWrap          = document.getElementById('ProductSku-' + sectionId);
  var inventoryEl      = document.getElementById('ProductInventory-' + sectionId);
  var atcBtn           = document.getElementById('ProductAddToCart-' + sectionId);
  var thumbsContainer  = document.getElementById('ProductThumbs-' + sectionId);
  var qtyInput         = document.getElementById('ProductQty-' + sectionId);

  /* Build variants map for quick lookup */
  var variantsMap = {};
  productData.forEach(function (v) { variantsMap[v.id] = v; });

  /* ── Variant change handler ── */
  function onVariantChange(variantId) {
    var selectedOpt = variantSelector
      ? variantSelector.querySelector('option[value="' + variantId + '"]')
      : null;
    if (!selectedOpt) return;

    var price         = parseInt(selectedOpt.dataset.price, 10);
    var comparePrice  = parseInt(selectedOpt.dataset.comparePrice, 10);
    var sku           = selectedOpt.dataset.sku;
    var invQty        = parseInt(selectedOpt.dataset.inventory, 10);
    var invMgmt       = selectedOpt.dataset.inventoryManagement;
    var available     = selectedOpt.dataset.available === 'true';
    var threshold     = inventoryEl ? parseInt(inventoryEl.dataset.threshold, 10) : 10;
    var showCount     = inventoryEl ? inventoryEl.dataset.showCount === 'true' : false;

    /* Update price */
    if (priceEl) {
      priceEl.textContent = formatMoney(price);
    }
    if (priceWrap) {
      var compareEl = priceWrap.querySelector('.product-page__price--compare');
      if (comparePrice && comparePrice > price) {
        if (!compareEl) {
          compareEl = document.createElement('s');
          compareEl.className = 'product-page__price--compare';
          priceWrap.insertBefore(compareEl, priceEl);
        }
        compareEl.textContent = formatMoney(comparePrice);
      } else if (compareEl) {
        compareEl.remove();
      }
    }

    /* Update SKU */
    if (skuEl) skuEl.textContent = sku || '';
    if (skuWrap) skuWrap.style.display = sku ? '' : 'none';

    /* Update inventory */
    if (inventoryEl) {
      var statusEl = inventoryEl.querySelector('[data-inventory-status]');
      if (statusEl) {
        var html = '';
        if (available) {
          if (showCount && invMgmt === 'shopify' && invQty <= threshold) {
            html = '<span class="pblock-inventory__low" data-inventory-status>'
                 + '<span class="pblock-inventory__dot pblock-inventory__dot--low"></span>'
                 + 'Only ' + invQty + ' left</span>';
          } else {
            html = '<span class="pblock-inventory__ok" data-inventory-status>'
                 + '<span class="pblock-inventory__dot pblock-inventory__dot--ok"></span>'
                 + 'In stock</span>';
          }
        } else {
          html = '<span class="pblock-inventory__sold" data-inventory-status>'
               + '<span class="pblock-inventory__dot pblock-inventory__dot--sold"></span>'
               + 'Sold out</span>';
        }
        inventoryEl.innerHTML = html;
      }
    }

    /* Update ATC button */
    if (atcBtn) {
      atcBtn.disabled = !available;
      atcBtn.textContent = available
        ? (atcBtn.dataset.atcLabel || 'Add to cart')
        : (atcBtn.dataset.soldLabel || 'Sold out');
    }
  }

  /* ── Radio / select → hidden variant selector sync ── */
  if (variantSelector) {
    var form = variantSelector.closest('form');
    if (form) {
      form.addEventListener('change', function (e) {
        var el = e.target;
        if (!el.matches('[data-option-index]')) return;

        /* Re-derive variant from all selected option values */
        var selectedValues = [];
        var optionGroups = form.querySelectorAll('[data-option-index]');
        var seen = new Set();
        optionGroups.forEach(function (input) {
          var idx = input.dataset.optionIndex;
          if (seen.has(idx)) return;
          if (input.type === 'radio' && !input.checked) return;
          seen.add(idx);
          selectedValues[parseInt(idx, 10)] = input.value;
        });

        /* Find matching variant */
        var match = productData.find(function (v) {
          return v.options.every(function (opt, i) {
            return opt === selectedValues[i];
          });
        });

        if (match) {
          variantSelector.value = match.id;
          onVariantChange(match.id);
        }
      });
    }

    /* Also listen to the hidden select directly (e.g. dropdown picker) */
    variantSelector.addEventListener('change', function () {
      onVariantChange(this.value);
    });
  }

  /* ── Quantity +/– ── */
  document.getElementById('QtyDecrease-' + sectionId)
    ?.addEventListener('click', function () {
      if (qtyInput && qtyInput.value > 1) qtyInput.value = parseInt(qtyInput.value, 10) - 1;
    });
  document.getElementById('QtyIncrease-' + sectionId)
    ?.addEventListener('click', function () {
      if (qtyInput) qtyInput.value = parseInt(qtyInput.value, 10) + 1;
    });

  /* ── Thumbnail gallery ── */
  if (thumbsContainer && mainImage) {
    var images = {{ product.images | json }};
    thumbsContainer.addEventListener('click', function (e) {
      var thumb = e.target.closest('.product-page__thumb');
      if (!thumb) return;
      var idx = parseInt(thumb.dataset.index, 10);
      if (images[idx]) {
        mainImage.src = images[idx].src.replace(/(\.(jpg|png|webp|gif))/, '_1000x$1');
        thumbsContainer.querySelectorAll('.product-page__thumb').forEach(function (t) {
          t.classList.remove('active');
        });
        thumb.classList.add('active');
      }
    });
  }

  /* ── Complementary products (Shopify recommendations API) ── */
  var compEl = document.getElementById('ComplementaryProducts-' + sectionId);
  if (compEl) {
    var productId = compEl.dataset.productId;
    var limit     = compEl.dataset.limit || 4;
    var grid      = document.getElementById('ComplementaryGrid-' + sectionId);
    if (productId && grid) {
      fetch('/recommendations/products.json?product_id=' + productId + '&limit=' + limit + '&intent=complementary')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.products || data.products.length === 0) {
            compEl.style.display = 'none';
            return;
          }
          var html = '';
          data.products.forEach(function (p) {
            var img = p.featured_image
              ? '<img src="' + p.featured_image + '" alt="' + p.title + '" loading="lazy">'
              : '';
            html += '<a href="' + p.url + '" class="pblock-comp-item">'
                  + img
                  + '<span>' + p.title + '</span></a>';
          });
          grid.innerHTML = html;
        })
        .catch(function () { compEl.style.display = 'none'; });
    }
  }
}());
</script>

