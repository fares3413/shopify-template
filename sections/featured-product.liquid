{%- liquid
  assign section_id = 'FeaturedProduct-' | append: section.id
  assign fp = all_products[section.settings.product]
  if fp == blank
    assign fp = product
  endif
-%}

<style>
  /* ── Section shell ── */
  #{{ section_id }} {
    padding-top:    {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background: var(--color-bg, #fff);
  }

  /* ── Stamp: centered above layout ── */
  #{{ section_id }} .fp-stamp-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 2.5rem;
  }
  #{{ section_id }} .fp-stamp {
    width: 110px;
    height: 110px;
    animation: fp-spin-{{ section.id }} 14s linear infinite;
  }
  @keyframes fp-spin-{{ section.id }} { to { transform: rotate(360deg); } }
  #{{ section_id }} .fp-stamp-text {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 2.5px;
    fill: var(--color-primary, #1a1a1a);
    text-transform: uppercase;
  }
  #{{ section_id }} .fp-stamp-icon {
    font-size: 20px;
  }

  /* ── Outer two-column grid ── */
  #{{ section_id }} .fp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Gallery: thumbnail strip + main image ── */
  #{{ section_id }} .fp-gallery {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 1rem;
    align-items: start;
  }

  /* ── Thumbnail strip ── */
  #{{ section_id }} .fp-thumbs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  #{{ section_id }} .fp-thumb {
    width: 72px;
    height: 72px;
    border: 2px solid transparent;
    border-radius: var(--radius-sm, 4px);
    overflow: hidden;
    background: var(--color-bg-soft, #f5f5f3);
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: border-color var(--transition, 0.25s ease);
  }
  #{{ section_id }} .fp-thumb.is-active {
    border-color: var(--color-primary, #1a1a1a);
  }
  #{{ section_id }} .fp-thumb img,
  #{{ section_id }} .fp-thumb svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Main image ── */
  #{{ section_id }} .fp-main-wrap {
    background: var(--color-bg-soft, #f5f5f3);
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ section_id }} .fp-main-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: opacity 0.2s ease;
  }
  #{{ section_id }} .fp-main-wrap svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Info column ── */
  #{{ section_id }} .fp-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Title + price ── */
  #{{ section_id }} .fp-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  #{{ section_id }} .fp-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-primary, #1a1a1a);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
    flex: 1;
  }
  #{{ section_id }} .fp-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    flex-shrink: 0;
  }
  #{{ section_id }} .fp-price__current {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-primary, #1a1a1a);
    white-space: nowrap;
  }
  #{{ section_id }} .fp-price__compare {
    font-size: 0.9rem;
    color: var(--color-text-muted, #888);
    text-decoration: line-through;
    white-space: nowrap;
  }

  /* ── Description ── */
  #{{ section_id }} .fp-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted, #888);
    margin: 0;
  }

  /* ── Add to cart ── */
  #{{ section_id }} .fp-atc {
    width: 100%;
    padding: 1.1rem 1.5rem;
    background: var(--color-primary, #1a1a1a);
    color: var(--color-white, #fff);
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: none;
    border-radius: var(--radius-full, 9999px);
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }
  #{{ section_id }} .fp-atc:hover:not(:disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  #{{ section_id }} .fp-atc:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Share row ── */
  #{{ section_id }} .fp-share-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.875rem 0;
    border-top: 1px solid var(--color-border, #e8e8e8);
    border-bottom: 1px solid var(--color-border, #e8e8e8);
  }
  #{{ section_id }} .fp-share {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #{{ section_id }} .fp-share-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted, #888);
    margin-right: 0.25rem;
  }
  #{{ section_id }} .fp-share-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary, #1a1a1a);
    border: 1px solid var(--color-border, #e8e8e8);
    border-radius: var(--radius-sm, 4px);
    transition: background var(--transition, 0.25s ease);
  }
  #{{ section_id }} .fp-share-icon:hover {
    background: var(--color-bg-soft, #f5f5f3);
  }
  #{{ section_id }} .fp-help {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted, #888);
    white-space: nowrap;
    transition: color var(--transition, 0.25s ease);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  #{{ section_id }} .fp-help:hover { color: var(--color-primary, #1a1a1a); }

  /* ── Trust features (no outer border box, just border-bottom per row) ── */
  #{{ section_id }} .fp-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  #{{ section_id }} .fp-feature {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 0;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-primary, #1a1a1a);
    border-bottom: 1px solid var(--color-border, #e8e8e8);
  }
  #{{ section_id }} .fp-feature:last-child { border-bottom: none; }
  #{{ section_id }} .fp-feature-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary, #1a1a1a);
    flex-shrink: 0;
  }

  /* ── View full details link ── */
  #{{ section_id }} .fp-view-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #1a1a1a);
    transition: gap var(--transition, 0.25s ease);
    width: fit-content;
  }
  #{{ section_id }} .fp-view-link:hover { gap: 0.625rem; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    #{{ section_id }} .fp-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 600px) {
    #{{ section_id }} .fp-gallery {
      grid-template-columns: 60px 1fr;
      gap: 0.75rem;
    }
    #{{ section_id }} .fp-thumb { width: 56px; height: 56px; }
    #{{ section_id }} .fp-stamp { width: 85px; height: 85px; }
  }
</style>

<section id="{{ section_id }}" class="featured-product-section">
  <div class="page-width">

    <!-- ── Spinning stamp ── -->
    <div class="fp-stamp-wrap" aria-hidden="true" data-reveal>
      <svg class="fp-stamp" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path id="fpCircle-{{ section.id }}" d="M 60,60 m -44,0 a 44,44 0 1,1 88,0 a 44,44 0 1,1 -88,0"/>
        </defs>
        <text class="fp-stamp-text">
          <textPath href="#fpCircle-{{ section.id }}" startOffset="0%">
            &#8226; FEATURED &#8226; PRODUCT &#8226;&nbsp;&nbsp;&#8226; FEATURED &#8226; PRODUCT &#8226;&nbsp;&nbsp;
          </textPath>
        </text>
        <text x="60" y="68" text-anchor="middle" class="fp-stamp-icon" aria-hidden="true">&#128077;</text>
      </svg>
    </div>

    <!-- ── Main two-column grid ── -->
    <div class="fp-grid">

      <!-- LEFT: gallery (thumbnails + main image) -->
      <div class="fp-gallery" data-reveal data-reveal-delay="100">

        <!-- Thumbnail strip -->
        <div class="fp-thumbs" id="FPThumbs-{{ section.id }}">
          {%- if fp != blank and fp.images.size > 0 -%}
            {%- for image in fp.images limit: 7 -%}
              <button
                class="fp-thumb{% if forloop.first %} is-active{% endif %}"
                data-src="{{ image | image_url: width: 900 }}"
                aria-label="View image {{ forloop.index }}"
                aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                <img
                  src="{{ image | image_url: width: 120 }}"
                  alt="{{ image.alt | default: fp.title | escape }}"
                  width="72" height="72"
                  loading="{{ forloop.first | iif: 'eager', 'lazy' }}"
                >
              </button>
            {%- endfor -%}
          {%- else -%}
            <button class="fp-thumb is-active" aria-pressed="true">{{ 'product-1' | placeholder_svg_tag }}</button>
            <button class="fp-thumb" aria-pressed="false">{{ 'product-2' | placeholder_svg_tag }}</button>
            <button class="fp-thumb" aria-pressed="false">{{ 'product-3' | placeholder_svg_tag }}</button>
            <button class="fp-thumb" aria-pressed="false">{{ 'product-4' | placeholder_svg_tag }}</button>
            <button class="fp-thumb" aria-pressed="false">{{ 'product-5' | placeholder_svg_tag }}</button>
          {%- endif -%}
        </div>

        <!-- Main image -->
        <div class="fp-main-wrap">
          {%- if fp != blank and fp.featured_image != blank -%}
            <img
              id="FPMainImage-{{ section.id }}"
              class="fp-main-img"
              src="{{ fp.featured_image | image_url: width: 900 }}"
              alt="{{ fp.featured_image.alt | default: fp.title | escape }}"
              width="{{ fp.featured_image.width }}"
              height="{{ fp.featured_image.height }}"
              loading="eager"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'fp-main-img' }}
          {%- endif -%}
        </div>

      </div>

      <!-- RIGHT: product info -->
      <div class="fp-info" data-reveal data-reveal-delay="220">

        <!-- Title + price -->
        <div class="fp-title-row">
          <h2 class="fp-title">
            {%- if fp != blank -%}{{ fp.title }}{%- else -%}Example product{%- endif -%}
          </h2>
          <div class="fp-price">
            {%- if fp != blank -%}
              {%- if fp.compare_at_price > fp.price -%}
                <s class="fp-price__compare">{{ fp.compare_at_price | money }}</s>
              {%- endif -%}
              <span class="fp-price__current">{{ fp.price | money }}</span>
            {%- else -%}
              <span class="fp-price__current">€19,99</span>
            {%- endif -%}
          </div>
        </div>

        <!-- Description -->
        {%- if fp != blank and fp.description != blank -%}
          <p class="fp-desc">{{ fp.description | strip_html | truncatewords: 35 }}</p>
        {%- else -%}
          <p class="fp-desc">This area is used to describe your product's details. Tell customers about the look, feel, and style of your product. Add details on color, materials used, sizing, and where it was made.</p>
        {%- endif -%}

        <!-- Add to cart -->
        {%- if fp != blank -%}
          {%- assign fp_form_id = 'FPForm-' | append: section.id -%}
          {%- form 'product', fp, id: fp_form_id, novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ fp.selected_or_first_available_variant.id }}">
            <button
              type="submit"
              class="fp-atc"
              {% unless fp.available %}disabled{% endunless %}
            >
              {%- if fp.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <button type="button" class="fp-atc">Add to cart</button>
        {%- endif -%}

        <!-- Share + Need help -->
        <div class="fp-share-row">
          <div class="fp-share">
            <span class="fp-share-label">Share:</span>
            {%- assign share_url = fp.url | default: request.path | full_url | url_encode -%}
            <a href="https://www.facebook.com/sharer/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on Facebook" class="fp-share-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?url={{ share_url }}" target="_blank" rel="noopener" aria-label="Share on X" class="fp-share-icon">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href="https://pinterest.com/pin/create/button/?url={{ share_url }}" target="_blank" rel="noopener" aria-label="Save to Pinterest" class="fp-share-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
            <a href="mailto:?subject={{ fp.title | default: 'Check this out' | url_encode }}&body={{ share_url }}" aria-label="Share via email" class="fp-share-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </a>
          </div>
          <a href="{{ fp.url | default: '#' }}" class="fp-help">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Need help?
          </a>
        </div>

        <!-- Trust items -->
        {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
        {%- if feature_blocks.size > 0 -%}
          <ul class="fp-features">
            {%- for block in feature_blocks -%}
              <li class="fp-feature" {{ block.shopify_attributes }}>
                <span class="fp-feature-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'headphone' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
                    {%- when 'gift' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
                    {%- else -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- endcase -%}
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <!-- View full details -->
        <a href="{{ fp.url | default: '#' }}" class="fp-view-link">
          <span>View full details</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>

      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var thumbContainer = document.getElementById('FPThumbs-{{ section.id }}');
  var mainImage = document.getElementById('FPMainImage-{{ section.id }}');
  if (!thumbContainer || !mainImage) return;
  var thumbs = thumbContainer.querySelectorAll('.fp-thumb[data-src]');
  thumbs.forEach(function (thumb) {
    thumb.addEventListener('click', function () {
      thumbs.forEach(function (t) {
        t.classList.remove('is-active');
        t.setAttribute('aria-pressed', 'false');
      });
      thumb.classList.add('is-active');
      thumb.setAttribute('aria-pressed', 'true');
      mainImage.src = thumb.dataset.src;
    });
  });
}());
</script>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck",     "label": "Truck (shipping)"    },
            { "value": "headphone", "label": "Headphone (support)" },
            { "value": "shield",    "label": "Shield (warranty)"   },
            { "value": "gift",      "label": "Gift (returns)"      }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "In stock! Ships within 1-2 business days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Product",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck",     "text": "In stock! Ships within 1-2 business days." } },
        { "type": "feature", "settings": { "icon": "headphone", "text": "90-day risk-free trial"                   } },
        { "type": "feature", "settings": { "icon": "shield",    "text": "2-Year Warranty"                         } },
        { "type": "feature", "settings": { "icon": "gift",      "text": "Complimentary shipping & returns"        } }
      ]
    }
  ]
}
{% endschema %}
