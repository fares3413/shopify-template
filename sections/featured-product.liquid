{%- liquid
  assign section_id = 'FeaturedProduct-' | append: section.id
  assign fp = all_products[section.settings.product]
  if fp == blank
    assign fp = product
  endif
-%}

<style>
  /* ── Section shell ── */
  #{{ section_id }} {
    padding-top:    {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background: var(--color-bg, #fff);
  }

  /* ── Stamp wrapper: centered above the grid ── */
  #{{ section_id }} .fp-stamp-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 2.5rem;
  }
  #{{ section_id }} .fp-stamp {
    width: 100px;
    height: 100px;
    animation: fp-spin-{{ section.id }} 14s linear infinite;
  }
  @keyframes fp-spin-{{ section.id }} {
    to { transform: rotate(360deg); }
  }
  #{{ section_id }} .fp-stamp-text {
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 2.5px;
    fill: var(--color-primary, #1a1a1a);
    text-transform: uppercase;
  }

  /* ── Two-column grid ── */
  #{{ section_id }} .fp-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* ── Product image ── */
  #{{ section_id }} .fp-image {
    background: var(--color-bg-soft, #f5f5f3);
    border-radius: var(--radius-md, 12px);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #{{ section_id }} .fp-image img,
  #{{ section_id }} .fp-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Info column ── */
  #{{ section_id }} .fp-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Title + price row ── */
  #{{ section_id }} .fp-title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  #{{ section_id }} .fp-title {
    font-family: var(--font-heading-family);
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 800;
    color: var(--color-primary, #1a1a1a);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
    flex: 1;
  }
  #{{ section_id }} .fp-price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    flex-shrink: 0;
  }
  #{{ section_id }} .fp-price__current {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-primary, #1a1a1a);
    white-space: nowrap;
  }
  #{{ section_id }} .fp-price__compare {
    font-size: 0.9rem;
    color: var(--color-text-muted, #888);
    text-decoration: line-through;
    white-space: nowrap;
  }

  /* ── Description ── */
  #{{ section_id }} .fp-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted, #888);
    margin: 0;
  }

  /* ── Add to cart button ── */
  #{{ section_id }} .fp-atc {
    width: 100%;
    padding: 1.1rem 1.5rem;
    background: var(--color-primary, #1a1a1a);
    color: var(--color-white, #fff);
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: none;
    border-radius: var(--radius-full, 9999px);
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.15s ease;
  }
  #{{ section_id }} .fp-atc:hover:not(:disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  #{{ section_id }} .fp-atc:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ── Trust items ── */
  #{{ section_id }} .fp-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border, #e8e8e8);
    border-radius: var(--radius-sm, 8px);
    overflow: hidden;
  }
  #{{ section_id }} .fp-feature {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.8rem 1rem;
    font-size: 0.875rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-border, #e8e8e8);
    transition: background var(--transition, 0.25s ease);
  }
  #{{ section_id }} .fp-feature:last-child { border-bottom: none; }
  #{{ section_id }} .fp-feature:hover { background: var(--color-bg-soft, #f5f5f3); }
  #{{ section_id }} .fp-feature-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-soft, #f5f5f3);
    border-radius: var(--radius-sm, 8px);
    flex-shrink: 0;
    color: var(--color-primary, #1a1a1a);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    #{{ section_id }} .fp-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    #{{ section_id }} .fp-stamp {
      width: 80px;
      height: 80px;
    }
  }
</style>

<section id="{{ section_id }}" class="featured-product-section">
  <div class="page-width">

    <!-- ── Circular spinning stamp ── -->
    <div class="fp-stamp-wrap" aria-hidden="true" data-reveal>
      <svg class="fp-stamp" viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <path
            id="fpCircle-{{ section.id }}"
            d="M 60,60 m -44,0 a 44,44 0 1,1 88,0 a 44,44 0 1,1 -88,0"
          />
        </defs>
        <text class="fp-stamp-text">
          <textPath href="#fpCircle-{{ section.id }}" startOffset="0%">
            &#8226; FEATURED &#8226; PRODUCT &#8226;&nbsp;&nbsp;&#8226; FEATURED &#8226; PRODUCT &#8226;&nbsp;&nbsp;
          </textPath>
        </text>
      </svg>
    </div>

    <!-- ── Two-column grid ── -->
    <div class="fp-grid">

      <!-- LEFT: product image -->
      <div class="fp-image" data-reveal data-reveal-delay="120">
        {%- if fp != blank and fp.featured_image != blank -%}
          <img
            src="{{ fp.featured_image | image_url: width: 900 }}"
            alt="{{ fp.featured_image.alt | default: fp.title | escape }}"
            width="{{ fp.featured_image.width }}"
            height="{{ fp.featured_image.height }}"
            loading="eager"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>

      <!-- RIGHT: product info -->
      <div class="fp-info" data-reveal data-reveal-delay="220">

        <!-- Title + price -->
        <div class="fp-title-row">
          <h2 class="fp-title">
            {%- if fp != blank -%}{{ fp.title }}{%- else -%}Example product{%- endif -%}
          </h2>
          <div class="fp-price">
            {%- if fp != blank -%}
              {%- if fp.compare_at_price > fp.price -%}
                <s class="fp-price__compare">{{ fp.compare_at_price | money }}</s>
              {%- endif -%}
              <span class="fp-price__current">{{ fp.price | money }}</span>
            {%- else -%}
              <span class="fp-price__current">€19,99</span>
            {%- endif -%}
          </div>
        </div>

        <!-- Description -->
        {%- if fp != blank and fp.description != blank -%}
          <p class="fp-desc">{{ fp.description | strip_html | truncatewords: 35 }}</p>
        {%- else -%}
          <p class="fp-desc">This area is used to describe your product's details. Tell customers about the look, feel, and style of your product. Add details on color, materials used, sizing, and where it was made.</p>
        {%- endif -%}

        <!-- Add to cart -->
        {%- if fp != blank -%}
          {%- form 'product', fp, id: 'FPForm-' | append: section.id, novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ fp.selected_or_first_available_variant.id }}">
            <button
              type="submit"
              class="fp-atc"
              {% unless fp.available %}disabled{% endunless %}
            >
              {%- if fp.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <button type="button" class="fp-atc">Add to cart</button>
        {%- endif -%}

        <!-- Trust items (optional blocks) -->
        {%- assign feature_blocks = section.blocks | where: 'type', 'feature' -%}
        {%- if feature_blocks.size > 0 -%}
          <ul class="fp-features">
            {%- for block in feature_blocks -%}
              <li class="fp-feature" {{ block.shopify_attributes }}>
                <span class="fp-feature-icon">
                  {%- case block.settings.icon -%}
                    {%- when 'truck' -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'headphone' -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg>
                    {%- when 'gift' -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
                    {%- else -%}
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- endcase -%}
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck",     "label": "Truck (shipping)"   },
            { "value": "headphone", "label": "Headphone (support)" },
            { "value": "shield",    "label": "Shield (warranty)"  },
            { "value": "gift",      "label": "Gift (returns)"     }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "In stock! Ships within 1-2 business days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Product",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck",     "text": "In stock! Ships within 1-2 business days." } },
        { "type": "feature", "settings": { "icon": "headphone", "text": "90-day risk-free trial"                   } },
        { "type": "feature", "settings": { "icon": "shield",    "text": "2-Year Warranty"                         } },
        { "type": "feature", "settings": { "icon": "gift",      "text": "Complimentary shipping & returns"        } }
      ]
    }
  ]
}
{% endschema %}
