{%- liquid
  assign section_id = 'ScrollCollage-' | append: section.id
  assign tiles = section.blocks | where: 'type', 'tile'
-%}

<style>
  /* ── Section shell ── */
  #{{ section_id }} {
    padding-top:    {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    background: var(--color-bg, #fff);
    overflow: hidden;
  }

  /* ── Two-column master layout ── */
  #{{ section_id }} .sc-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── LEFT: text column ── */
  #{{ section_id }} .sc-text {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  #{{ section_id }} .sc-text__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--color-primary, #1a1a1a);
    line-height: 1.05;
    margin: 0;
  }
  #{{ section_id }} .sc-text__desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text, #1a1a1a);
    opacity: 0.75;
    margin: 0;
  }
  #{{ section_id }} .sc-text__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border: 2px solid var(--color-primary, #1a1a1a);
    border-radius: var(--radius-full, 9999px);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary, #1a1a1a);
    text-decoration: none;
    width: fit-content;
    transition: background var(--transition, 0.25s ease),
                color var(--transition, 0.25s ease);
  }
  #{{ section_id }} .sc-text__btn:hover {
    background: var(--color-primary, #1a1a1a);
    color: var(--color-white, #fff);
  }
  #{{ section_id }} .sc-text__btn svg {
    transition: transform var(--transition, 0.25s ease);
  }
  #{{ section_id }} .sc-text__btn:hover svg { transform: translateX(3px); }

  /* ── RIGHT: collage grid ── */
  #{{ section_id }} .sc-collage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 340px 280px;
    gap: 1rem;
  }

  /* Tile position overrides */
  #{{ section_id }} .sc-tile:nth-child(1) { grid-column: 1; grid-row: 1; }
  #{{ section_id }} .sc-tile:nth-child(2) { grid-column: 2; grid-row: 1 / span 2; }
  #{{ section_id }} .sc-tile:nth-child(3) { grid-column: 1; grid-row: 2; }
  #{{ section_id }} .sc-tile:nth-child(4) { grid-column: 2; grid-row: 3; }

  /* ── Single tile ── */
  #{{ section_id }} .sc-tile {
    position: relative;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    background: var(--color-bg-muted, #ebebeb);
    /* Scroll-reveal start state */
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  #{{ section_id }} .sc-tile.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
  /* Stagger delays */
  #{{ section_id }} .sc-tile:nth-child(1) { transition-delay: 0s; }
  #{{ section_id }} .sc-tile:nth-child(2) { transition-delay: 0.1s; }
  #{{ section_id }} .sc-tile:nth-child(3) { transition-delay: 0.2s; }
  #{{ section_id }} .sc-tile:nth-child(4) { transition-delay: 0.3s; }

  /* ── Tile image ── */
  #{{ section_id }} .sc-tile__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  #{{ section_id }} .sc-tile:hover .sc-tile__img { transform: scale(1.04); }

  /* ── Tile placeholder ── */
  #{{ section_id }} .sc-tile__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-muted, #ebebeb);
  }
  #{{ section_id }} .sc-tile__placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  /* ── Tile overlay + content ── */
  #{{ section_id }} .sc-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.05) 50%, transparent 100%);
  }
  #{{ section_id }} .sc-tile__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 1.5rem;
  }
  #{{ section_id }} .sc-tile__tagline {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent, #c9a96e);
    margin-bottom: 0.3rem;
  }
  #{{ section_id }} .sc-tile__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 800;
    color: var(--color-white, #fff);
    line-height: 1.2;
    margin: 0;
  }

  /* ── Tile link ── */
  #{{ section_id }} .sc-tile__link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    #{{ section_id }} .sc-layout {
      grid-template-columns: 1fr;
    }
    #{{ section_id }} .sc-text {
      position: static;
      max-width: 480px;
    }
    #{{ section_id }} .sc-collage {
      grid-template-rows: 260px 260px auto;
    }
  }
  @media (max-width: 600px) {
    #{{ section_id }} .sc-collage {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    #{{ section_id }} .sc-tile { min-height: 220px; }
    #{{ section_id }} .sc-tile:nth-child(n) {
      grid-column: 1;
      grid-row: auto;
    }
  }
</style>

<section id="{{ section_id }}" class="scroll-collage">
  <div class="page-width">
    <div class="sc-layout">

      <!-- ── Left text column ── -->
      <div class="sc-text">
        {%- if section.settings.heading != blank -%}
          <h2 class="sc-text__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="sc-text__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="sc-text__btn">
            {{ section.settings.button_label }}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      <!-- ── Right collage ── -->
      <div class="sc-collage">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tile' -%}
            <div class="sc-tile" {{ block.shopify_attributes }}>

              {%- comment -%} Image or placeholder {%- endcomment -%}
              {%- if block.settings.image != blank -%}
                <img
                  class="sc-tile__img"
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  alt="{{ block.settings.heading | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              {%- else -%}
                <div class="sc-tile__placeholder">
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag }}
                </div>
              {%- endif -%}

              {%- comment -%} Gradient overlay {%- endcomment -%}
              <div class="sc-tile__overlay" aria-hidden="true"></div>

              {%- comment -%} Text content {%- endcomment -%}
              <div class="sc-tile__content">
                {%- if block.settings.tagline != blank -%}
                  <span class="sc-tile__tagline">{{ block.settings.tagline }}</span>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="sc-tile__heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
              </div>

              {%- comment -%} Full-tile link {%- endcomment -%}
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="sc-tile__link" aria-label="{{ block.settings.heading | escape }}"></a>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  /* ── Intersection Observer: reveal tiles on scroll ── */
  var tiles = document.querySelectorAll('#ScrollCollage-{{ section.id }} .sc-tile');
  if (!tiles.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    tiles.forEach(function (tile) { observer.observe(tile); });
  } else {
    /* Fallback: show all immediately */
    tiles.forEach(function (t) { t.classList.add('is-visible'); });
  }
}());
</script>

{% schema %}
{
  "name": "Collage on scroll",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collage"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collage tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Tagline"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Example heading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collage on scroll",
      "blocks": [
        { "type": "tile", "settings": { "tagline": "Tagline", "heading": "Example heading" } },
        { "type": "tile", "settings": { "tagline": "Tagline", "heading": "Example heading" } },
        { "type": "tile", "settings": { "tagline": "Tagline", "heading": "Example heading" } },
        { "type": "tile", "settings": { "tagline": "Tagline", "heading": "Example heading" } }
      ]
    }
  ]
}
{% endschema %}
