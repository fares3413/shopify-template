{%- liquid
  assign section_id = 'PDA-' | append: section.id
-%}

<style>
  #{{ section_id }} {
    padding-top:    {{ section.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
    background: var(--color-bg, #fff);
  }

  /* ── Heading ── */
  #{{ section_id }} .pda-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    color: var(--color-primary, #1a1a1a);
    margin: 0 0 2rem;
    line-height: 1.15;
  }

  /* ── Accordion wrapper ── */
  #{{ section_id }} .pda-list {
    border-top: 1px solid var(--color-border, #e8e8e8);
  }

  /* ── Single item ── */
  #{{ section_id }} .pda-item {
    border-bottom: 1px solid var(--color-border, #e8e8e8);
  }

  /* ── Toggle button ── */
  #{{ section_id }} .pda-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.375rem 0;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-primary, #1a1a1a);
    text-align: left;
  }
  #{{ section_id }} .pda-toggle:hover { opacity: 0.7; }

  /* ── Icon (+/×) ── */
  #{{ section_id }} .pda-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-primary, #1a1a1a);
    transition: transform var(--transition, 0.25s ease),
                opacity var(--transition, 0.25s ease);
    user-select: none;
  }

  /* ── Content panel (CSS grid height animation) ── */
  #{{ section_id }} .pda-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  #{{ section_id }} .pda-panel__inner {
    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.32s ease;
  }
  #{{ section_id }} .pda-item--open .pda-panel {
    grid-template-rows: 1fr;
  }
  #{{ section_id }} .pda-item--open .pda-panel__inner {
    padding-bottom: 1.25rem;
  }

  /* ── Content text ── */
  #{{ section_id }} .pda-panel__inner .rte {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-muted, #888);
    max-width: 70ch;
  }

  @media (max-width: 600px) {
    #{{ section_id }} .pda-toggle { font-size: 0.9375rem; padding: 1.1rem 0; }
  }
</style>

<section id="{{ section_id }}" class="product-details-accordion">
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="pda-heading" data-reveal>{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="pda-list" role="list" data-reveal-stagger data-stagger-delay="80">
      {%- for block in section.blocks -%}
        {%- assign is_open = forloop.first -%}
        <div
          class="pda-item{% if is_open %} pda-item--open{% endif %}"
          role="listitem"
          data-reveal-item
          {{ block.shopify_attributes }}
        >
          <button
            class="pda-toggle"
            aria-expanded="{{ is_open }}"
            aria-controls="pda-panel-{{ block.id }}"
          >
            <span class="pda-toggle__label">{{ block.settings.row_title | default: 'Collapsible row' }}</span>
            <span class="pda-icon" aria-hidden="true">
              {%- if is_open -%}&times;{%- else -%}+{%- endif -%}
            </span>
          </button>

          <div
            class="pda-panel"
            id="pda-panel-{{ block.id }}"
            role="region"
            aria-labelledby="pda-btn-{{ block.id }}"
          >
            <div class="pda-panel__inner">
              <div class="rte">{{ block.settings.row_content }}</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
(function () {
  var list = document.querySelector('#PDA-{{ section.id }} .pda-list');
  if (!list) return;

  list.addEventListener('click', function (e) {
    var btn = e.target.closest('.pda-toggle');
    if (!btn) return;

    var item    = btn.closest('.pda-item');
    var isOpen  = item.classList.contains('pda-item--open');

    /* Close every item */
    list.querySelectorAll('.pda-item').forEach(function (el) {
      el.classList.remove('pda-item--open');
      var b = el.querySelector('.pda-toggle');
      b.setAttribute('aria-expanded', 'false');
      b.querySelector('.pda-icon').innerHTML = '+';
    });

    /* Re-open if it was closed */
    if (!isOpen) {
      item.classList.add('pda-item--open');
      btn.setAttribute('aria-expanded', 'true');
      btn.querySelector('.pda-icon').innerHTML = '&times;';
    }
  });
}());
</script>

{% schema %}
{
  "name": "Product details",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product details"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 120, "step": 4, "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "row_title",
          "label": "Row title",
          "default": "Collapsible row"
        },
        {
          "type": "richtext",
          "id": "row_content",
          "label": "Row content",
          "default": "<p>Use this text to share information about your brand with your customers. Describe a product, share announcements, or welcome customers to your store.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product details",
      "blocks": [
        { "type": "row", "settings": { "row_title": "Collapsible row 1" } },
        { "type": "row", "settings": { "row_title": "Collapsible row 2" } },
        { "type": "row", "settings": { "row_title": "Collapsible row 3" } },
        { "type": "row", "settings": { "row_title": "Collapsible row 4" } }
      ]
    }
  ]
}
{% endschema %}
