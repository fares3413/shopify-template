{%- liquid
  assign cols_desktop  = section.settings.columns_desktop | default: 4
  assign cols_mobile   = section.settings.columns_mobile | default: '2'
  assign card_style    = section.settings.card_style | default: 'card'
  assign image_ratio   = section.settings.image_ratio | default: 'square'
  assign heading_tag   = section.settings.heading_tag | default: 'h2'
  assign heading_size  = section.settings.heading_size | default: 'md'
  assign heading_align = section.settings.heading_alignment | default: 'left'
  assign hl_style      = section.settings.heading_highlight_style | default: 'none'
-%}

<style>
  #FeaturedCollections-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | default: 60 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 60 }}px;
    {%- unless section.settings.color_text == 'rgba(0,0,0,0)' or section.settings.color_text == blank -%}
      color: {{ section.settings.color_text }};
    {%- endunless -%}
    {%- unless section.settings.color_background == 'rgba(0,0,0,0)' or section.settings.color_background == blank -%}
      background-color: {{ section.settings.color_background }};
    {%- endunless -%}
  }

  /* Clipping wrapper — height is set by JS to exactly 3 rows */
  #FeaturedCollections-{{ section.id }} .cl-vscroll-wrapper {
    overflow: hidden;
    position: relative;
  }

  /* ── Grid: 4 columns, wrapped rows, no horizontal overflow ── */
  #FeaturedCollections-{{ section.id }} .cl-carousel__track {
    display: grid !important;
    grid-template-columns: repeat({{ cols_desktop }}, 1fr) !important;
    grid-auto-flow: row !important;
    grid-auto-rows: auto !important;
    gap: 1.25rem !important;
    overflow: visible !important;
    max-height: none !important;
    scroll-snap-type: none !important;
    will-change: transform;
  }

  /* Hide the nav arrow buttons — not needed for this layout */
  #FeaturedCollections-{{ section.id }} .cl-carousel__btn { display: none !important; }

  {%- unless section.settings.color_button_background == 'rgba(0,0,0,0)' or section.settings.color_button_background == blank -%}
    #FeaturedCollections-{{ section.id }} .cl-section__view-all {
      background: {{ section.settings.color_button_background }};
      border-color: {{ section.settings.color_button_background }};
    }
  {%- endunless -%}
  {%- unless section.settings.color_button_text == 'rgba(0,0,0,0)' or section.settings.color_button_text == blank -%}
    #FeaturedCollections-{{ section.id }} .cl-section__view-all {
      color: {{ section.settings.color_button_text }};
    }
  {%- endunless -%}
  {%- if section.settings.custom_css != blank -%}
    #FeaturedCollections-{{ section.id }} { {{ section.settings.custom_css }} }
  {%- endif -%}

  /* Tablet: 2 columns */
  @media (max-width: 1024px) {
    #FeaturedCollections-{{ section.id }} .cl-carousel__track {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  /* Mobile: set by columns_mobile setting */
  @media (max-width: 640px) {
    #FeaturedCollections-{{ section.id }} .cl-carousel__track {
      grid-template-columns: repeat({{ cols_mobile }}, 1fr) !important;
      gap: 0.75rem !important;
    }
  }
</style>

<section
  id="FeaturedCollections-{{ section.id }}"
  class="cl-section{% if section.settings.show_divider %} cl-section--divider{% endif %}{% if section.settings.full_width %} cl-section--full{% endif %}{% if section.settings.rounded %} cl-section--rounded{% endif %} cl-section--hl-{{ hl_style }}"
>
  <div class="{% unless section.settings.full_width %}page-width{% endunless %}">

    <!-- Section header -->
    {%- if section.settings.heading != blank or section.settings.subheading != blank or section.settings.description != blank -%}
      <div class="cl-header cl-header--{{ heading_align }}">
        {%- if section.settings.subheading != blank -%}
          <p class="cl-header__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="cl-header__heading cl-header__heading--{{ heading_size }}">
            {{- section.settings.heading -}}
          </{{ heading_tag }}>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="cl-header__desc">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Scroll wrapper clips to 3 rows; JS adds clones + animates when needed -->
    <div class="cl-vscroll-wrapper" id="CLWrapper-{{ section.id }}">
      <div class="cl-carousel__track" id="CLTrack-{{ section.id }}">

        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          {%- assign col_title  = collection.title | default: block.settings.label | default: 'Collection' -%}
          {%- assign col_href   = collection.url | default: block.settings.custom_link | default: '#' -%}

          {%- liquid
            assign src_img = nil
            if block.settings.image != blank
              assign src_img = block.settings.image
            elsif section.settings.image_source == 'first_product' and collection != blank
              assign first_prod = collection.products.first
              if first_prod.featured_image != blank
                assign src_img = first_prod.featured_image
              elsif collection.featured_image != blank
                assign src_img = collection.featured_image
              endif
            elsif collection != blank and collection.featured_image != blank
              assign src_img = collection.featured_image
            endif
          -%}

          <div class="cl-card cl-card--{{ card_style }} cl-card--{{ image_ratio }}" {{ block.shopify_attributes }}>
            <a href="{{ col_href }}" class="cl-card__inner">

              <div class="cl-card__media">
                {%- if src_img != nil -%}
                  <img
                    src="{{ src_img | image_url: width: 800 }}"
                    alt="{{ col_title | escape }}"
                    class="cl-card__img"
                    loading="lazy"
                    width="{{ src_img.width | default: 800 }}"
                    height="{{ src_img.height | default: 800 }}"
                  >
                {%- else -%}
                  {%- assign placeholder_index = forloop.index0 | modulo: 6 | plus: 1 -%}
                  {{ 'collection-' | append: placeholder_index | placeholder_svg_tag: 'cl-card__placeholder' }}
                {%- endif -%}

                {%- if card_style == 'image' -%}
                  <div class="cl-card__img-overlay">
                    <div class="cl-card__img-info">
                      <div>
                        <span class="cl-card__title">{{ col_title }}</span>
                        {%- if section.settings.show_product_count and collection != blank -%}
                          <span class="cl-card__count">{{ collection.products_count }} products</span>
                        {%- endif -%}
                      </div>
                      <span class="cl-card__arrow" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M10.5 4.5 15 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    </div>
                  </div>
                {%- endif -%}
              </div>

              {%- if card_style == 'card' -%}
                <div class="cl-card__info">
                  <div class="cl-card__info-text">
                    <span class="cl-card__title">{{ col_title }}</span>
                    {%- if section.settings.show_product_count and collection != blank -%}
                      <span class="cl-card__count">{{ collection.products_count }} products</span>
                    {%- endif -%}
                  </div>
                  <span class="cl-card__arrow" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M3 9h12M10.5 4.5 15 9l-4.5 4.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                </div>
              {%- endif -%}

            </a>
          </div>
        {%- endfor -%}

      </div><!-- /.cl-carousel__track -->
    </div><!-- /.cl-vscroll-wrapper -->

    {%- if section.settings.show_view_all -%}
      <div class="cl-section__footer">
        <a href="/collections" class="btn btn--outline cl-section__view-all">View all collections</a>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
(function () {
  var VISIBLE_ROWS = 3;
  var SPEED        = 0.5; // px per frame  ≈ 30 px/s at 60 fps

  var wrapper = document.getElementById('CLWrapper-{{ section.id }}');
  var track   = document.getElementById('CLTrack-{{ section.id }}');
  if (!wrapper || !track) return;

  /* Original card elements (Liquid-rendered, never clones) */
  var origCards  = Array.from(track.children);
  var totalCards = origCards.length;

  /* ── Detect actual rendered column count from DOM layout ── */
  function getRenderedCols() {
    if (origCards.length < 2) return 1;
    var top0 = origCards[0].getBoundingClientRect().top;
    var n = 0;
    for (var i = 0; i < origCards.length; i++) {
      if (Math.abs(origCards[i].getBoundingClientRect().top - top0) < 5) { n++; } else { break; }
    }
    return n || 1;
  }

  /* ── Animation state ── */
  var scrollY   = 0;
  var origScrollH = 0;
  var rafId     = null;
  var paused    = false;
  var running   = false;

  /* ── Pause on hover/focus so users can read cards ── */
  wrapper.addEventListener('mouseenter', function () { paused = true;  });
  wrapper.addEventListener('mouseleave', function () { paused = false; });
  wrapper.addEventListener('focusin',    function () { paused = true;  });
  wrapper.addEventListener('focusout',   function () { paused = false; });

  /* ── Remove any previously injected clones ── */
  function removeClones() {
    track.querySelectorAll('[data-vclone]').forEach(function (el) { el.remove(); });
  }

  /* ── Core setup: measure, clone, animate ── */
  function setup() {
    removeClones();
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; running = false; }
    scrollY = 0;
    track.style.transform = '';
    wrapper.style.height  = '';

    /* Wait one tick so the grid has laid out after clone removal */
    requestAnimationFrame(function () {
      var cols     = getRenderedCols();
      var totalRows = Math.ceil(totalCards / cols);

      /* Nothing to scroll — show a plain static grid */
      if (totalRows <= VISIBLE_ROWS) return;

      /* ── Clone every original card for seamless looping ── */
      origCards.forEach(function (card) {
        var clone = card.cloneNode(true);
        clone.setAttribute('data-vclone', '1');
        clone.setAttribute('aria-hidden', 'true');
        /* Strip Shopify editor hooks so the editor doesn't double-count blocks */
        clone.removeAttribute('data-shopify-editor-block');
        clone.querySelectorAll('[data-shopify-editor-block]').forEach(function (el) {
          el.removeAttribute('data-shopify-editor-block');
        });
        track.appendChild(clone);
      });

      /* ── Measure after clones are in the DOM ── */
      requestAnimationFrame(function () {
        var style  = window.getComputedStyle(track);
        var gap    = parseFloat(style.rowGap) || parseFloat(style.gap) || 20;
        var cardH  = origCards[0].offsetHeight;

        /*
          origScrollH = height of ONE full set of original cards inside the grid.
          After scrolling this far, the clone set starts — visually identical → seamless.
        */
        origScrollH = totalRows * (cardH + gap);

        /* Clip the wrapper to show exactly VISIBLE_ROWS rows */
        wrapper.style.height = (VISIBLE_ROWS * (cardH + gap) - gap) + 'px';

        /* Kick off the RAF loop */
        running = true;
        rafId   = requestAnimationFrame(tick);
      });
    });
  }

  function tick() {
    if (!paused && origScrollH > 0) {
      scrollY += SPEED;
      if (scrollY >= origScrollH) { scrollY -= origScrollH; }
      track.style.transform = 'translateY(-' + scrollY + 'px)';
    }
    if (running) { rafId = requestAnimationFrame(tick); }
  }

  /* ── Init after layout is ready ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }

  /* ── Re-initialise on resize (columns change on mobile) ── */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { scrollY = 0; setup(); }, 250);
  });
}());
</script>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ],
      "default": "md"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "info": "Specify heading code types for SEO and search engines for crawling purposes.",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Highlighted text"
    },
    {
      "type": "paragraph",
      "content": "To add an animated highlight to text, simply wrap it in italics. Click the \"I\" button in the editor to toggle italics when highlighting text."
    },
    {
      "type": "select",
      "id": "heading_highlight_style",
      "label": "Highlighted text",
      "options": [
        { "value": "none",      "label": "None" },
        { "value": "underline", "label": "Underline" },
        { "value": "italic",    "label": "Italic (accent color)" },
        { "value": "bold",      "label": "Bold" },
        { "value": "color",     "label": "Accent color" },
        { "value": "highlight", "label": "Highlight badge" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "paragraph",
      "content": "Gradient replaces solid colors when set."
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Background"
    },
    {
      "type": "color",
      "id": "color_highlight",
      "label": "Highlight"
    },
    {
      "type": "color",
      "id": "color_button_text",
      "label": "Button text"
    },
    {
      "type": "color",
      "id": "color_button_background",
      "label": "Button background"
    },
    {
      "type": "header",
      "content": "Cards layout"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Style",
      "options": [
        { "value": "card",  "label": "Card" },
        { "value": "image", "label": "Image" }
      ],
      "default": "card"
    },
    {
      "type": "select",
      "id": "image_source",
      "label": "Image",
      "options": [
        { "value": "collection", "label": "Collection image" },
        { "value": "first_product", "label": "First product image" }
      ],
      "default": "collection"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square",    "label": "Square" },
        { "value": "portrait",  "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" },
        { "value": "adapt",     "label": "Adapt to image" }
      ],
      "default": "square"
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show total number of products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Enable \"View all\" button",
      "info": "If list includes more collections than shown.",
      "default": false
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Number of columns on desktop",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "label": "Enable carousel on desktop",
      "default": true
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Number of columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "enable_swipe",
      "label": "Enable swipe on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show section divider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Make section full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "label": "Make section rounded",
      "default": false
    },
    {
      "type": "header",
      "content": "Custom CSS"
    },
    {
      "type": "textarea",
      "id": "custom_css",
      "label": "CSS"
    }
  ],
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label (fallback if no collection)",
          "default": "Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (overrides collection image)"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom link (if no collection)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        { "type": "collection_item", "settings": { "label": "All Products" } },
        { "type": "collection_item", "settings": { "label": "Headphones" } },
        { "type": "collection_item", "settings": { "label": "Earphones" } },
        { "type": "collection_item", "settings": { "label": "Speakers" } }
      ]
    }
  ]
}
{% endschema %}
