{%- assign s     = section.settings -%}
{%- assign sid   = section.id -%}
{%- assign total = section.blocks | size -%}

{%- comment -%} ── Layout metrics (all computed in Liquid → rendered into CSS) ── {%- endcomment -%}
{%- assign cols     = s.columns      | default: 3 -%}
{%- assign card_w   = s.card_width   | default: 280 -%}
{%- assign card_h   = s.card_height  | default: 340 -%}
{%- assign gap      = s.card_gap     | default: 20 -%}
{%- assign vis      = s.visible_rows | default: 2 -%}
{%- assign spd      = s.scroll_speed | default: 60 -%}

{%- comment -%} rows = ceil(total / cols) using integer ceiling formula {%- endcomment -%}
{%- assign rows_raw = total | plus: cols | minus: 1 -%}
{%- assign rows     = rows_raw | divided_by: cols -%}
{%- if rows < 1 -%}{%- assign rows = 1 -%}{%- endif -%}

{%- comment -%}
  shift   = pixels the track must travel to complete one loop cycle.
            = rows × (card_h + gap)  — this is where the clone set starts.
  dur     = shift / speed  (seconds). Clamped to ≥ 4s.
  wrap_h  = clipping window height = vis × (card_h + gap) − gap.
  grid_w  = exact pixel width of the grid (no gutters, no page-width padding).
{%- endcomment -%}
{%- assign row_h    = card_h | plus: gap -%}
{%- assign shift    = rows   | times: row_h -%}
{%- assign dur_raw  = shift  | divided_by: spd -%}
{%- if dur_raw < 4 -%}{%- assign dur = 4 -%}{%- else -%}{%- assign dur = dur_raw -%}{%- endif -%}
{%- assign wrap_h   = vis | times: row_h | minus: gap -%}
{%- assign cols_m1  = cols | minus: 1 -%}
{%- assign gap_sum  = cols_m1 | times: gap -%}
{%- assign grid_w   = card_w | times: cols | plus: gap_sum -%}

<style>
/* ════════════════════════════════════════════════════
   Scroll Carousel  ·  section #ScrollCarousel-{{ sid }}
   ════════════════════════════════════════════════════ */
#ScrollCarousel-{{ sid }} {
  background: {{ s.bg_color | default: '#1a1a1a' }};
  padding: 5rem 0;
  overflow: hidden;
}

/* ── Section header — centred, matches page typography ── */
#ScrollCarousel-{{ sid }} .sc__header {
  text-align: center;
  max-width: var(--page-width, 1320px);
  margin: 0 auto;
  padding: 0 var(--gutter, 2rem) 3.5rem;
}
#ScrollCarousel-{{ sid }} .sc__eyebrow {
  display: inline-block;
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-accent, #c9a96e);
  margin: 0 0 1rem;
}
#ScrollCarousel-{{ sid }} .sc__heading {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: clamp(1.75rem, 3vw, 2.75rem);
  font-weight: 800;
  color: {{ s.text_color | default: '#ffffff' }};
  margin: 0 0 0.875rem;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
#ScrollCarousel-{{ sid }} .sc__desc {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 1rem;
  line-height: 1.7;
  color: {{ s.text_color | default: '#ffffff' }};
  opacity: 0.55;
  max-width: 520px;
  margin: 0 auto;
}

/* ── Clip window — exact height of visible_rows, centred ── */
#ScrollCarousel-{{ sid }} .sc__clip {
  width: {{ grid_w }}px;
  max-width: calc(100vw - 2 * var(--gutter, 2rem));
  height: {{ wrap_h }}px;
  margin: 0 auto;
  overflow: hidden;
  position: relative;
  /* Soft fade on top and bottom edges */
  -webkit-mask-image: linear-gradient(
    to bottom,
    transparent 0%,
    #000 7%,
    #000 93%,
    transparent 100%
  );
  mask-image: linear-gradient(
    to bottom,
    transparent 0%,
    #000 7%,
    #000 93%,
    transparent 100%
  );
}

/* ── CSS keyframe — moves track up by exactly one original set height ── */
@keyframes sc-scroll-up-{{ sid }} {
  from { transform: translateY(0); }
  to   { transform: translateY(-{{ shift }}px); }
}

/* ── Grid track — original cards + clones stack into rows ── */
#ScrollCarousel-{{ sid }} .sc__track {
  display: grid;
  grid-template-columns: repeat({{ cols }}, {{ card_w }}px);
  gap: {{ gap }}px;
  width: {{ grid_w }}px;
  animation: sc-scroll-up-{{ sid }} {{ dur }}s linear infinite;
}

/* Pause on hover or keyboard focus inside the clip */
#ScrollCarousel-{{ sid }} .sc__clip:hover .sc__track,
#ScrollCarousel-{{ sid }} .sc__clip:focus-within .sc__track {
  animation-play-state: paused;
}

/* ════════════════
   Card — styled to match the page (white card on dark section)
   ════════════════ */
#ScrollCarousel-{{ sid }} .sc__card {
  width: {{ card_w }}px;
  height: {{ card_h }}px;
  border-radius: var(--radius-lg, 16px);
  overflow: hidden;
  background: var(--color-bg, #ffffff);
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.14);
  transition: transform 0.32s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              box-shadow 0.32s ease;
}
#ScrollCarousel-{{ sid }} .sc__card:hover {
  transform: translateY(-5px) scale(1.018);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
}

/* Card inner — link or div wrapper fills the full card */
#ScrollCarousel-{{ sid }} .sc__card-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  color: inherit;
}

/* Image area fills remaining height above the info strip */
#ScrollCarousel-{{ sid }} .sc__card-img-wrap {
  flex: 1;
  overflow: hidden;
  background: var(--color-bg-soft, #f5f5f3);
  position: relative;
}
#ScrollCarousel-{{ sid }} .sc__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
#ScrollCarousel-{{ sid }} .sc__card:hover .sc__card-img {
  transform: scale(1.06);
}
#ScrollCarousel-{{ sid }} .sc__card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-muted, #ebebeb);
}
#ScrollCarousel-{{ sid }} .sc__card-placeholder svg {
  width: 40px;
  height: 40px;
  opacity: 0.28;
  color: var(--color-text-muted, #888);
}

/* Info strip — exactly matches cl-card__info style from the theme */
#ScrollCarousel-{{ sid }} .sc__card-body {
  flex-shrink: 0;
  padding: 0.75rem 1rem 0.875rem;
  border-top: 1px solid var(--color-border, #e8e8e8);
  background: var(--color-bg, #ffffff);
}
#ScrollCarousel-{{ sid }} .sc__card-label {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-primary, #1a1a1a);
  letter-spacing: -0.01em;
  margin: 0 0 0.2rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
#ScrollCarousel-{{ sid }} .sc__card-sublabel {
  font-family: var(--font-body-family, 'Inter', sans-serif);
  font-size: 0.75rem;
  color: var(--color-text-muted, #888);
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Mobile: switch to horizontal drag-scroll ── */
@media (max-width: 768px) {
  #ScrollCarousel-{{ sid }} {
    padding: 3.5rem 0;
  }
  #ScrollCarousel-{{ sid }} .sc__clip {
    width: 100%;
    height: auto !important;
    overflow-x: auto;
    overflow-y: visible;
    scrollbar-width: none;
    padding: 0.5rem var(--gutter, 1.5rem) 1rem;
    box-sizing: border-box;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 5%,
      #000 95%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      #000 5%,
      #000 95%,
      transparent 100%
    );
  }
  #ScrollCarousel-{{ sid }} .sc__clip::-webkit-scrollbar { display: none; }
  #ScrollCarousel-{{ sid }} .sc__track {
    animation: none !important;
    /* Single row, all cards side-by-side */
    grid-template-columns: repeat({{ total | times: 2 }}, min({{ card_w }}px, 70vw));
    width: max-content;
  }
  /* Hide the cloned set on mobile (we don't need loop clones for drag-scroll) */
  #ScrollCarousel-{{ sid }} .sc__track .sc__card[aria-hidden="true"] {
    display: none;
  }
  #ScrollCarousel-{{ sid }} .sc__card {
    width: min({{ card_w }}px, 70vw);
    height: auto;
  }
  #ScrollCarousel-{{ sid }} .sc__card-img-wrap {
    flex: none;
    aspect-ratio: 4 / 3;
  }
}
</style>

<div id="ScrollCarousel-{{ sid }}">

  {%- if s.eyebrow != blank or s.heading != blank or s.description != blank -%}
    <div class="sc__header">
      {%- if s.eyebrow != blank -%}
        <p class="sc__eyebrow">{{ s.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if s.heading != blank -%}
        <h2 class="sc__heading">{{ s.heading | escape }}</h2>
      {%- endif -%}
      {%- if s.description != blank -%}
        <p class="sc__desc">{{ s.description | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="sc__clip" id="ScClip-{{ sid }}">
    <div class="sc__track">

      {%- comment -%} ── Original cards ── {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="sc__card" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="sc__card-inner">
          {%- else -%}
            <div class="sc__card-inner">
          {%- endif -%}
              <div class="sc__card-img-wrap">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
                    class="sc__card-img"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {%- else -%}
                  <div class="sc__card-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>
              {%- if block.settings.label != blank or block.settings.sublabel != blank -%}
                <div class="sc__card-body">
                  {%- if block.settings.label != blank -%}
                    <p class="sc__card-label">{{ block.settings.label | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.sublabel != blank -%}
                    <p class="sc__card-sublabel">{{ block.settings.sublabel | escape }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- comment -%} ── Clone set — makes the loop seamless (hidden from screen readers) ── {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="sc__card" aria-hidden="true">
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="sc__card-inner" tabindex="-1">
          {%- else -%}
            <div class="sc__card-inner">
          {%- endif -%}
              <div class="sc__card-img-wrap">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt=""
                    class="sc__card-img"
                    loading="lazy"
                    width="800"
                    height="800"
                  >
                {%- else -%}
                  <div class="sc__card-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>
              {%- if block.settings.label != blank or block.settings.sublabel != blank -%}
                <div class="sc__card-body">
                  {%- if block.settings.label != blank -%}
                    <p class="sc__card-label">{{ block.settings.label | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.sublabel != blank -%}
                    <p class="sc__card-sublabel">{{ block.settings.sublabel | escape }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>
  </div>

</div>

{% schema %}
{
  "name": "Scroll Carousel",
  "tag": "section",
  "class": "section-scroll-carousel",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore the Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Cards per row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "visible_rows",
      "label": "Visible rows",
      "info": "How many rows are visible at once before the rest scroll in",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Card size"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Card width (px)",
      "min": 160,
      "max": 400,
      "step": 20,
      "default": 280
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card height (px)",
      "min": 200,
      "max": 600,
      "step": 20,
      "default": 340
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 20
    },
    {
      "type": "header",
      "content": "Auto-scroll animation"
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "label": "Scroll speed (px / second)",
      "info": "Higher = faster. Cards pause on hover.",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 60
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading / text",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sublabel (e.g. price or category)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scroll Carousel",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
