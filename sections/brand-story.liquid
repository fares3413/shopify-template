<section class="brand-story section-padding" id="BrandStory-{{ section.id }}">
  <div class="page-width">
    <div class="brand-story__inner">

      <!-- Left: heading + button -->
      <div class="brand-story__left">
        <h2 class="brand-story__heading">
          {{ section.settings.heading }}
          {%- if section.settings.show_underline -%}
            <span class="brand-story__underline" aria-hidden="true"></span>
          {%- endif -%}
        </h2>
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--outline">
            {{ section.settings.button_label }}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        {%- endif -%}

        <!-- Stats blocks -->
        {%- assign stats = section.blocks | where: 'type', 'stat' -%}
        {%- if stats.size > 0 -%}
          <div class="brand-story__stats">
            {%- for block in stats -%}
              <div class="brand-story__stat" {{ block.shopify_attributes }}>
                <span class="brand-story__stat-value">{{ block.settings.value }}</span>
                <span class="brand-story__stat-label">{{ block.settings.label }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Right: text + optional image -->
      <div class="brand-story__right">
        {%- if section.settings.image != blank -%}
          <div class="brand-story__image-wrap">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              alt="{{ section.settings.image.alt | escape }}"
              class="brand-story__image"
              loading="lazy"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          </div>
        {%- endif -%}
        {%- if section.settings.text_1 != blank -%}
          <div class="brand-story__text brand-story__text--lead rte">{{ section.settings.text_1 }}</div>
        {%- endif -%}
        {%- if section.settings.text_2 != blank -%}
          <div class="brand-story__text rte">{{ section.settings.text_2 }}</div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "We believe in the power of sound"
    },
    {
      "type": "checkbox",
      "id": "show_underline",
      "label": "Show decorative underline",
      "default": true
    },
    {
      "type": "richtext",
      "id": "text_1",
      "label": "First paragraph (lead)",
      "default": "<p><strong>Harmony Sound</strong> is more than just an audio equipment retailer. We represent the grandeur of sound in its finest manifestations. Our mission is to cater to audiophiles and those who simply appreciate quality sound.</p>"
    },
    {
      "type": "richtext",
      "id": "text_2",
      "label": "Second paragraph",
      "default": "<p>We offer everything from the warm sound of vinyl records to the clarity and crispness of modern wireless headphones, ensuring every note sounds impeccable.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Optional image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "10K+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy customers"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "blocks": [
        { "type": "stat", "settings": { "value": "10K+", "label": "Happy customers" } },
        { "type": "stat", "settings": { "value": "50+", "label": "Premium brands" } },
        { "type": "stat", "settings": { "value": "15yr", "label": "Experience" } }
      ]
    }
  ]
}
{% endschema %}
