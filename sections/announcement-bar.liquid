{%- if section.settings.show_bar -%}
{%- assign social_pos = section.settings.social_position | default: 'left' -%}
<div
  class="announcement-bar"
  id="AnnouncementBar-{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.speed }}"
  role="region"
  aria-label="Announcements"
>
  <div class="announcement-bar__content">

    <!-- Left slot -->
    <div class="announcement-bar__left">
      {%- if social_pos == 'left' -%}
        <div class="announcement-bar__social" aria-label="Social links">
          <a href="{{ settings.social_facebook_link | default: '#' }}" {% if settings.social_facebook_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>
          <a href="{{ settings.social_twitter_link | default: '#' }}" {% if settings.social_twitter_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="X">{% render 'icon-x' %}</a>
          <a href="{{ settings.social_instagram_link | default: '#' }}" {% if settings.social_instagram_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>
          <a href="{{ settings.social_tiktok_link | default: '#' }}" {% if settings.social_tiktok_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="TikTok">{% render 'icon-tiktok' %}</a>
          <a href="{{ settings.social_youtube_link | default: '#' }}" {% if settings.social_youtube_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>
        </div>
        {%- if section.blocks.size > 0 -%}
          <span class="announcement-bar__separator" aria-hidden="true"></span>
        {%- endif -%}
      {%- endif -%}
    </div>

    <!-- Center: prev | messages | next -->
    <div class="announcement-bar__center">
      {%- if section.blocks.size > 1 -%}
        <button
          class="announcement-bar__nav announcement-bar__nav--prev"
          aria-label="Previous announcement"
          id="AnnPrev-{{ section.id }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
      {%- endif -%}

      <div class="announcement-bar__messages" aria-live="polite" aria-atomic="true">
        {%- for block in section.blocks -%}
          <div
            class="announcement-bar__message{% if forloop.first %} is-active{% endif %}"
            aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="announcement-bar__message-link">
            {%- endif -%}

            {%- unless block.settings.icon == 'none' -%}
              <span class="announcement-bar__message-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'mail' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  {%- when 'gift' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  {%- when 'star' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- when 'tag' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                  {%- when 'info' -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {%- endcase -%}
              </span>
            {%- endunless -%}

            <span>{{ block.settings.text }}</span>

            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > 1 -%}
        <button
          class="announcement-bar__nav announcement-bar__nav--next"
          aria-label="Next announcement"
          id="AnnNext-{{ section.id }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      {%- endif -%}
    </div>

    <!-- Right slot -->
    <div class="announcement-bar__right">
      {%- if social_pos == 'right' -%}
        {%- if section.blocks.size > 0 -%}
          <span class="announcement-bar__separator" aria-hidden="true"></span>
        {%- endif -%}
        <div class="announcement-bar__social" aria-label="Social links">
          <a href="{{ settings.social_facebook_link | default: '#' }}" {% if settings.social_facebook_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="Facebook">{% render 'icon-facebook' %}</a>
          <a href="{{ settings.social_twitter_link | default: '#' }}" {% if settings.social_twitter_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="X">{% render 'icon-x' %}</a>
          <a href="{{ settings.social_instagram_link | default: '#' }}" {% if settings.social_instagram_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="Instagram">{% render 'icon-instagram' %}</a>
          <a href="{{ settings.social_tiktok_link | default: '#' }}" {% if settings.social_tiktok_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="TikTok">{% render 'icon-tiktok' %}</a>
          <a href="{{ settings.social_youtube_link | default: '#' }}" {% if settings.social_youtube_link != blank %}target="_blank" rel="noopener"{% endif %} class="announcement-bar__social-link" aria-label="YouTube">{% render 'icon-youtube' %}</a>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{%- if section.blocks.size > 1 -%}
<script>
(function () {
  var bar      = document.getElementById('AnnouncementBar-{{ section.id }}');
  if (!bar) return;
  var messages = bar.querySelectorAll('.announcement-bar__message');
  var prevBtn  = bar.querySelector('.announcement-bar__nav--prev');
  var nextBtn  = bar.querySelector('.announcement-bar__nav--next');
  var autoplay = bar.dataset.autoplay === 'true';
  var speed    = parseInt(bar.dataset.speed, 10) || 4000;
  var current  = 0;
  var total    = messages.length;
  var timer    = null;

  if (total <= 1) return;

  function goTo(idx) {
    messages[current].classList.remove('is-active');
    messages[current].setAttribute('aria-hidden', 'true');
    current = (idx + total) % total;
    messages[current].classList.add('is-active');
    messages[current].setAttribute('aria-hidden', 'false');
  }

  function start() {
    if (!autoplay) return;
    clearInterval(timer);
    timer = setInterval(function () { goTo(current + 1); }, speed);
  }

  prevBtn && prevBtn.addEventListener('click', function () { goTo(current - 1); start(); });
  nextBtn && nextBtn.addEventListener('click', function () { goTo(current + 1); start(); });

  /* Pause on hover */
  bar.addEventListener('mouseenter', function () { clearInterval(timer); });
  bar.addEventListener('mouseleave', start);

  start();
}());
</script>
{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "select",
      "id": "social_position",
      "label": "Social icons",
      "options": [
        { "value": "left",   "label": "Show on left" },
        { "value": "right",  "label": "Show on right" },
        { "value": "hidden", "label": "Hide" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate announcements",
      "default": true
    },
    {
      "type": "select",
      "id": "speed",
      "label": "Rotate every",
      "options": [
        { "value": "2000", "label": "2 seconds" },
        { "value": "3000", "label": "3 seconds" },
        { "value": "4000", "label": "4 seconds" },
        { "value": "5000", "label": "5 seconds" },
        { "value": "7000", "label": "7 seconds" }
      ],
      "default": "4000"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping and returns"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none",  "label": "None" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "mail",  "label": "Mail (contact)" },
            { "value": "gift",  "label": "Gift" },
            { "value": "star",  "label": "Star" },
            { "value": "tag",   "label": "Tag (promo)" },
            { "value": "info",  "label": "Info" }
          ],
          "default": "truck"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Free shipping and returns", "icon": "truck" } },
        { "type": "announcement", "settings": { "text": "A question? Visit our contact page", "icon": "mail" } },
        { "type": "announcement", "settings": { "text": "Get 20% off your first order", "icon": "tag" } }
      ]
    }
  ]
}
{% endschema %}
