{%- liquid
  assign msg         = settings.cookie_message       | default: 'This site uses cookies for better user experience and analytics.'
  assign lbl_accept  = settings.cookie_accept_label  | default: 'Accept'
  assign lbl_decline = settings.cookie_decline_label | default: 'Decline'
  assign policy_url  = settings.cookie_policy_link   | default: '/policies/privacy-policy'
-%}

<style>
/* ══════════════════════════════════
   EU Cookie Banner — Centered Card
   ══════════════════════════════════ */

#EuCookieOverlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 9999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 2.5rem;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s ease;
}

#EuCookieOverlay.is-visible {
  opacity: 1;
  pointer-events: auto;
}

#EuCookieBanner {
  background: #ffffff;
  border-radius: 24px;
  width: min(480px, calc(100vw - 2rem));
  padding: 2.25rem 2rem 2rem;
  text-align: center;
  box-shadow:
    0 24px 64px rgba(0, 0, 0, 0.18),
    0 4px 16px  rgba(0, 0, 0, 0.08);

  /* Spring pop-in */
  transform: translateY(40px) scale(0.96);
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

#EuCookieOverlay.is-visible #EuCookieBanner {
  transform: translateY(0) scale(1);
}

.eu-ck__title {
  font-size: 1.25rem;
  font-weight: 800;
  color: #1a1a1a;
  margin: 0 0 0.875rem;
  letter-spacing: -0.02em;
}

.eu-ck__desc {
  font-size: 0.9375rem;
  line-height: 1.65;
  color: #555555;
  margin: 0 0 1.75rem;
}

.eu-ck__policy {
  color: #1a1a1a;
  text-decoration: underline;
  text-underline-offset: 2px;
  font-weight: 600;
}

.eu-ck__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
}

/* Base button */
.eu-ck__btn {
  flex: 1;
  max-width: 180px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.875rem 1.5rem;
  border-radius: 50px;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  border: 2px solid transparent;
  cursor: pointer;
  transition:
    transform  0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.25s ease,
    background 0.2s ease;
}

.eu-ck__btn:hover  { transform: translateY(-2px) scale(1.03); }
.eu-ck__btn:active { transform: scale(0.97); }

/* Accept — black filled */
.eu-ck__btn--accept {
  background: #1a1a1a;
  color: #ffffff;
  border-color: #1a1a1a;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.2);
}
.eu-ck__btn--accept:hover {
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
}

/* Decline — white outlined */
.eu-ck__btn--decline {
  background: #ffffff;
  color: #1a1a1a;
  border-color: #1a1a1a;
}
.eu-ck__btn--decline:hover {
  background: #f5f5f5;
}

/* Mobile */
@media (max-width: 480px) {
  #EuCookieOverlay {
    align-items: flex-end;
    padding-bottom: 0;
  }

  #EuCookieBanner {
    width: 100%;
    border-radius: 24px 24px 0 0;
    padding: 2rem 1.5rem 2.5rem;
  }

  .eu-ck__actions {
    flex-direction: column;
    align-items: stretch;
  }

  .eu-ck__btn { max-width: 100%; }
}

@media (prefers-reduced-motion: reduce) {
  #EuCookieOverlay, #EuCookieBanner, .eu-ck__btn {
    transition: opacity 0.2s ease !important;
    transform: none !important;
  }
}
</style>

<div id="EuCookieOverlay" role="dialog" aria-modal="true" aria-label="Cookie consent" aria-hidden="true">
  <div id="EuCookieBanner">

    <h2 class="eu-ck__title">We use cookies</h2>

    <p class="eu-ck__desc">
      {{ msg }}
      {%- if policy_url != blank -%}
        <br><a href="{{ policy_url }}" class="eu-ck__policy" target="_blank" rel="noopener">Privacy Policy</a>
      {%- endif -%}
    </p>

    <div class="eu-ck__actions">
      <button type="button" class="eu-ck__btn eu-ck__btn--accept" id="EuCookieAccept">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        {{ lbl_accept }}
      </button>
      <button type="button" class="eu-ck__btn eu-ck__btn--decline" id="EuCookieDecline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        {{ lbl_decline }}
      </button>
    </div>

  </div>
</div>

<script>
(function () {
  var overlay    = document.getElementById('EuCookieOverlay');
  var acceptBtn  = document.getElementById('EuCookieAccept');
  var declineBtn = document.getElementById('EuCookieDecline');
  if (!overlay) return;

  var COOKIE_KEY = 'eu_ck_consent_v2';

  function getCk(name) {
    var m = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
    return m ? m.pop() : null;
  }
  function setCk(name, val, days) {
    var d = new Date();
    d.setTime(d.getTime() + days * 864e5);
    document.cookie = name + '=' + val + ';expires=' + d.toUTCString() + ';path=/;SameSite=Lax';
  }

  function show() {
    overlay.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        overlay.classList.add('is-visible');
      });
    });
  }

  function hide(callback) {
    overlay.classList.remove('is-visible');
    overlay.setAttribute('aria-hidden', 'true');
    setTimeout(function () { if (callback) callback(); }, 400);
  }

  /* Already consented — bail out */
  if (getCk(COOKIE_KEY)) return;

  /* ── Try Shopify Privacy API first ── */
  function runWithAPI(api) {
    var needed = false;
    try { needed = api.shouldShowBanner(); }     catch(e) {}
    if (!needed) { try { needed = api.shouldShowGDPRBanner(); } catch(e) {} }
    if (!needed) needed = true; /* always show when no cookie set */

    if (!needed) return;
    setTimeout(show, 600);

    acceptBtn && acceptBtn.addEventListener('click', function () {
      setCk(COOKIE_KEY, 'accepted', 365);
      try { api.setTrackingConsent(true, function () { hide(function () { window.location.reload(); }); }); }
      catch(e) { hide(); }
    });

    declineBtn && declineBtn.addEventListener('click', function () {
      setCk(COOKIE_KEY, 'declined', 30);
      try { api.setTrackingConsent(false, function () { hide(); }); }
      catch(e) { hide(); }
    });
  }

  /* ── Fallback (no Shopify API) ── */
  function runFallback() {
    setTimeout(show, 600);
    acceptBtn  && acceptBtn.addEventListener('click',  function () { setCk(COOKIE_KEY, 'accepted', 365); hide(); });
    declineBtn && declineBtn.addEventListener('click', function () { setCk(COOKIE_KEY, 'declined', 30);  hide(); });
  }

  /* ── Bootstrap ── */
  if (window.Shopify && window.Shopify.customerPrivacy) {
    runWithAPI(window.Shopify.customerPrivacy);
  } else if (window.Shopify && window.Shopify.loadFeatures) {
    window.Shopify.loadFeatures([{ name: 'consent-tracking-api', version: '0.1' }], function (err) {
      if (err || !window.Shopify.customerPrivacy) { runFallback(); return; }
      runWithAPI(window.Shopify.customerPrivacy);
    });
  } else {
    runFallback();
  }

}());
</script>
