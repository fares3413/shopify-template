{%- unless settings.show_sidebar_social -%}

<style>
/* ════════════════════════════════════════════════════
   Promo Sidebar Tab  ·  Global promo display
   ════════════════════════════════════════════════════ */

.promo-sidebar-global {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 100px;
  height: auto;
  background: #ffffff;
  border-radius: 0 20px 20px 0;
  box-shadow: 0 10px 50px rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  padding: 2.5rem 1.25rem;
  z-index: 999;
  cursor: pointer;
  transition:
    box-shadow 0.3s var(--ease-component, ease),
    transform 0.3s var(--ease-component, ease);
}

.promo-sidebar-global:hover {
  box-shadow: 0 15px 60px rgba(0, 0, 0, 0.2);
  transform: translateY(-50%) translateX(5px);
}

.promo-sidebar__socials {
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
  align-items: center;
  justify-content: center;
}

.promo-sidebar__social-link {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #ffffff;
  border: 1.5px solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a1a;
  font-size: 1.25rem;
  font-weight: 700;
  text-decoration: none;
  transition:
    background 0.3s var(--ease-component, ease),
    border-color 0.3s var(--ease-component, ease),
    transform 0.3s var(--ease-component, ease),
    color 0.3s var(--ease-component, ease);
  cursor: pointer;
  pointer-events: none;
}

.promo-sidebar-global:hover .promo-sidebar__social-link {
  transform: scale(1.1);
  background: #1a1a1a;
  color: #ffffff;
  border-color: #1a1a1a;
}

.promo-sidebar__promo {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  text-align: center;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: 0.7rem;
  font-weight: 800;
  color: #1a1a1a;
  white-space: nowrap;
  line-height: 1.2;
  padding: 1rem 0;
  pointer-events: none;
}

/* Mobile: hide on small screens */
@media (max-width: 768px) {
  .promo-sidebar-global {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .promo-sidebar-global,
  .promo-sidebar__social-link {
    transition: none;
  }
}
</style>

<div class="promo-sidebar-global" id="PromoSidebarTab">
  <!-- Social Links -->
  <div class="promo-sidebar__socials">
    {%- if settings.social_facebook_link != blank -%}
      <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="Facebook">f</a>
    {%- endif -%}
    {%- if settings.social_twitter_link != blank -%}
      <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="X">𝕏</a>
    {%- endif -%}
    {%- if settings.social_instagram_link != blank -%}
      <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="Instagram">📷</a>
    {%- endif -%}
    {%- if settings.social_youtube_link != blank -%}
      <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="YouTube">▶</a>
    {%- endif -%}
  </div>

  <!-- Promo Text (clickable) -->
  <p class="promo-sidebar__promo">{{ settings.promo_tab_text | default: 'GET 20% OFF' }}</p>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var sidebarTab = document.getElementById('PromoSidebarTab');
  var popup = document.getElementById('NewsletterPopup');

  if (!sidebarTab || !popup) return;

  // Open popup when sidebar is clicked
  sidebarTab.addEventListener('click', function (e) {
    // Don't open popup if clicking on social links
    if (e.target.closest('.promo-sidebar__social-link')) {
      return;
    }

    popup.setAttribute('aria-hidden', 'false');
    popup.classList.add('is-open');
    document.body.style.overflow = 'hidden';

    setTimeout(function () {
      var input = popup.querySelector('.nl-popup__input');
      if (input) input.focus();
    }, 300);
  });
});
</script>

{%- endunless -%}
