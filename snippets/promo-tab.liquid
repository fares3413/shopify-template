{%- unless settings.show_sidebar_social -%}

<style>
/* ════════════════════════════════════════════════════
   Promo Sidebar Tab  ·  Global promo display
   ════════════════════════════════════════════════════ */

.promo-sidebar-global {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 100px;
  background: #ffffff;
  border-radius: 0 16px 16px 0;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  padding: 2rem 1rem;
  z-index: 999;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.promo-sidebar__socials {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  align-items: center;
}

.promo-sidebar__social-link {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5f5f5 0%, #ebebeb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a1a1a;
  font-size: 1.1rem;
  font-weight: 700;
  text-decoration: none;
  transition:
    background 0.3s var(--ease-component, ease),
    transform 0.3s var(--ease-component, ease),
    color 0.3s var(--ease-component, ease);
  border: 2px solid transparent;
}

.promo-sidebar__social-link:hover {
  background: #c9a96e;
  color: #ffffff;
  transform: scale(1.15);
}

.promo-sidebar__promo {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  text-align: center;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-size: 0.75rem;
  font-weight: 700;
  color: #c9a96e;
  white-space: nowrap;
  padding: 1rem 0;
}

.promo-sidebar__btn {
  padding: 0.75rem 1.5rem;
  background: #c9a96e;
  color: #ffffff;
  border: 2px solid #c9a96e;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: 0.05em;
  transition:
    background 0.3s var(--ease-component, ease),
    transform 0.3s var(--ease-component, ease);
  cursor: pointer;
  white-space: nowrap;
  text-align: center;
}

.promo-sidebar__btn:hover {
  background: #e8c89e;
  border-color: #e8c89e;
  transform: translateY(-2px);
}

/* Mobile: hide on small screens */
@media (max-width: 768px) {
  .promo-sidebar-global {
    display: none;
  }
}
</style>

<div class="promo-sidebar-global">
  <!-- Social Links -->
  <div class="promo-sidebar__socials">
    {%- if settings.social_facebook_link != blank -%}
      <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="Facebook" aria-label="Follow on Facebook">f</a>
    {%- endif -%}
    {%- if settings.social_twitter_link != blank -%}
      <a href="{{ settings.social_twitter_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="X (Twitter)" aria-label="Follow on X">𝕏</a>
    {%- endif -%}
    {%- if settings.social_instagram_link != blank -%}
      <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="Instagram" aria-label="Follow on Instagram">📷</a>
    {%- endif -%}
    {%- if settings.social_youtube_link != blank -%}
      <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener noreferrer" class="promo-sidebar__social-link" title="YouTube" aria-label="Subscribe on YouTube">▶</a>
    {%- endif -%}
  </div>

  <!-- Promo Text -->
  <p class="promo-sidebar__promo">{{ settings.promo_tab_text | default: 'GET 20% OFF' }}</p>

  <!-- CTA Button -->
  {%- if settings.popup_enabled -%}
    <button class="promo-sidebar__btn" id="PromoSidebarBtn" type="button">
      SHOP
    </button>
    <script>
    document.addEventListener('DOMContentLoaded', function () {
      var btn = document.getElementById('PromoSidebarBtn');
      var popup = document.getElementById('NewsletterPopup');
      if (!btn || !popup) return;
      btn.addEventListener('click', function () {
        popup.setAttribute('aria-hidden', 'false');
        popup.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        setTimeout(function () {
          var input = popup.querySelector('.nl-popup__input');
          if (input) input.focus();
        }, 300);
      });
    });
    </script>
  {%- else -%}
    <a href="{{ settings.promo_tab_link | default: routes.collections_url }}" class="promo-sidebar__btn">
      SHOP
    </a>
  {%- endif -%}
</div>

{%- endunless -%}
