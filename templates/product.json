{
  "sections": {
    "main": {
      "type": "product-main",
      "blocks": {
        "vendor": {
          "type": "vendor",
          "settings": {}
        },
        "title": {
          "type": "title",
          "settings": {}
        },
        "price": {
          "type": "price",
          "settings": {}
        },
        "sku": {
          "type": "sku",
          "settings": {}
        },
        "separator_1": {
          "type": "separator",
          "settings": {
            "show_line": true,
            "space_size": 8
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "show_selected_value": true
          }
        },
        "description": {
          "type": "description",
          "settings": {}
        },
        "inventory": {
          "type": "inventory",
          "settings": {
            "show_count": true,
            "inventory_threshold": 10
          }
        },
        "quantity_selector": {
          "type": "quantity_selector",
          "settings": {
            "show_label": true,
            "label": "Quantity"
          }
        },
        "add_to_cart_buttons": {
          "type": "add_to_cart_buttons",
          "settings": {
            "atc_label": "Add to cart",
            "sold_out_label": "Sold out",
            "show_dynamic_checkout": true
          }
        },
        "collapsible_tab_1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "How It Works",
            "content": "<p>Describe how your product works or highlight key benefits here.</p>",
            "open_by_default": false
          }
        },
        "collapsible_tab_2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "content": "<p>Free shipping on orders over $150. Returns accepted within 30 days of delivery. Items must be unused and in original packaging.</p>",
            "open_by_default": false
          }
        },
        "pickup_availability": {
          "type": "pickup_availability",
          "settings": {}
        },
        "complementary_products": {
          "type": "complementary_products",
          "settings": {
            "heading": "You may also like",
            "products_to_show": 4
          }
        },
        "share_buttons": {
          "type": "share_buttons",
          "settings": {
            "show_label": true,
            "label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "sku",
        "separator_1",
        "variant_picker",
        "description",
        "inventory",
        "quantity_selector",
        "add_to_cart_buttons",
        "collapsible_tab_1",
        "collapsible_tab_2",
        "pickup_availability",
        "complementary_products",
        "share_buttons"
      ],
      "settings": {
        "show_vendor": true,
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "product_recommendations": {
      "type": "product-recommendations",
      "settings": {}
    }
  },
  "order": ["main", "product_recommendations"]
}
